# SOCRadar Entra ID Integration — App Settings
# Copy to .env and fill in values (for local testing only)

# SOCRadar API
SOCRADAR_API_KEY=your_platform_api_key_here
SOCRADAR_IDENTITY_API_KEY=your_identity_api_key_here   # optional, pay-per-use
SOCRADAR_COMPANY_ID=330
MONITORED_DOMAINS=contoso.com,fabrikam.com   # comma-separated, used by Identity Intelligence

# Entra ID App Registration
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret

# Entra ID Security Group (for ENABLE_ADD_TO_GROUP)
SECURITY_GROUP_ID=

# Log Analytics Workspace
WORKSPACE_ID=your-workspace-id
WORKSPACE_KEY=your-workspace-key

# Storage Account (checkpoint state — set automatically by ARM template)
STORAGE_ACCOUNT_NAME=

# Source toggles (true/false)
ENABLE_IDENTITY_SOURCE=true
ENABLE_BOTNET_SOURCE=true
ENABLE_PII_SOURCE=true
ENABLE_VIP_SOURCE=false   # UNVERIFIED endpoint

# Action toggles
ENABLE_ROPC=false                    # password validation via ROPC (discouraged by MS)
ENABLE_REVOKE_SESSION=true
ENABLE_ADD_TO_GROUP=true
ENABLE_PASSWORD_CHANGE=false
ENABLE_DISABLE_ACCOUNT=false
ENABLE_CONFIRM_RISKY=false           # requires Entra ID P1/P2
ENABLE_CREATE_INCIDENT=false

# Password logging (false = sanitized only, true = plaintext written to LAW)
ENABLE_LOG_PLAINTEXT_PASSWORD=false

# Polling schedule (cron expression)
POLLING_SCHEDULE=0 */6 * * *

# Initial lookback for first run (minutes)
INITIAL_LOOKBACK_MINUTES=600

# Sentinel workspace (only required if ENABLE_CREATE_INCIDENT=true)
WORKSPACE_NAME=
WORKSPACE_LOCATION=
WORKSPACE_RESOURCE_GROUP=

# Azure deployment
RESOURCE_GROUP=your-resource-group
LOCATION=northeurope
