{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "title": "SOCRadar Entra ID Integration for Microsoft Sentinel",
        "description": "Pulls leaked employee credentials from SOCRadar (Botnet, PII Exposure, VIP Protection) and takes automated remediation actions in Microsoft Entra ID. Logs to Microsoft Sentinel custom tables.",
        "version": "1.0.0",
        "author": "SOCRadar",
        "lastUpdateTime": "2026-03-26T00:00:00.000Z"
    },
    "parameters": {
        "WorkspaceName": {
            "type": "string",
            "metadata": {
                "description": "Microsoft Sentinel Log Analytics Workspace Name"
            }
        },
        "WorkspaceLocation": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Location/region of the Log Analytics workspace"
            }
        },
        "SocradarApiKey": {
            "type": "securestring",
            "metadata": {
                "description": "SOCRadar Platform API Key (used for Botnet, PII Exposure, VIP Protection sources)"
            }
        },
        "SocradarCompanyId": {
            "type": "string",
            "metadata": {
                "description": "SOCRadar Company ID"
            }
        },
        "EntraIdTenantId": {
            "type": "string",
            "metadata": {
                "description": "Microsoft Entra ID Tenant ID"
            }
        },
        "EntraIdClientId": {
            "type": "string",
            "metadata": {
                "description": "App Registration Client ID (must have required Graph API permissions)"
            }
        },
        "EntraIdClientSecret": {
            "type": "securestring",
            "metadata": {
                "description": "App Registration Client Secret"
            }
        },
        "SecurityGroupId": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "Entra ID Security Group ID for compromised users (required if EnableAddToGroup=true)"
            }
        },
        "EnableBotnetSource": {
            "type": "bool",
            "defaultValue": true,
            "metadata": {
                "description": "Enable Botnet Data v2 source"
            }
        },
        "EnablePiiSource": {
            "type": "bool",
            "defaultValue": true,
            "metadata": {
                "description": "Enable PII Exposure v2 source"
            }
        },
        "EnableVipSource": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Enable VIP Protection v2 source (UNVERIFIED: endpoint not in official API documentation)"
            }
        },
        "EnableRevokeSession": {
            "type": "bool",
            "defaultValue": true,
            "metadata": {
                "description": "Revoke all active sign-in sessions for compromised users"
            }
        },
        "EnableAddToGroup": {
            "type": "bool",
            "defaultValue": true,
            "metadata": {
                "description": "Add compromised users to security group (requires SecurityGroupId)"
            }
        },
        "EnablePasswordChange": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Force password change on next sign-in for compromised users"
            }
        },
        "EnableDisableAccount": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Disable compromised user accounts (use with caution)"
            }
        },
        "EnableConfirmRisky": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Confirm compromised users in Identity Protection (requires Entra ID P1/P2 license)"
            }
        },
        "EnableROPC": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Validate leaked credentials via ROPC (Resource Owner Password Credentials). Only possible with plaintext passwords. Requires Allow public client flows on App Registration. Microsoft discourages ROPC in production."
            }
        },
        "EnableCreateIncident": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Create Microsoft Sentinel incidents for compromised accounts"
            }
        },
        "EnableResolveAlarm": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Automatically resolve SOCRadar alarms when compromised user is found in Entra ID"
            }
        },
        "EnableLogPlaintextPassword": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Write plaintext passwords to Log Analytics tables. By default only password_present/masked fields are stored. Enable only if your security policy requires it."
            }
        },
        "PollingIntervalHours": {
            "type": "int",
            "defaultValue": 6,
            "minValue": 1,
            "maxValue": 24,
            "metadata": {
                "description": "How often to check for new leaked credentials (1-24 hours)"
            }
        },
        "InitialLookbackMinutes": {
            "type": "int",
            "defaultValue": 600,
            "minValue": 0,
            "maxValue": 43200,
            "metadata": {
                "description": "Minutes of history to fetch on first run (600 = 10 hours). Uses epoch time internally."
            }
        },
        "WorkspaceResourceGroup": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "Resource group of the Log Analytics workspace (for cross-RG deployments). Leave empty if same as deployment RG."
            }
        }
    },
    "variables": {
        "functionAppName": "[concat('socradar-entraid-', uniqueString(resourceGroup().id))]",
        "managedIdentityName": "SOCRadar-EntraID-MI",
        "hostingPlanName": "SOCRadar-EntraID-Plan",
        "storageAccountName": "[take(concat('srentraid', uniqueString(resourceGroup().id)), 24)]",
        "tableName": "EntraIDState",
        "appInsightsName": "[concat('socradar-entraid-ai-', uniqueString(resourceGroup().id))]",
        "StorageTableDataContributorRoleId": "0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3",
        "WebsiteContributorRoleId": "de139f84-1756-47ae-9be6-808fbbe84772",
        "workspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('WorkspaceName'))]",
        "pollingSchedule": "[concat('0 0 */', string(parameters('PollingIntervalHours')), ' * * *')]"
    },
    "resources": [
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-05-01",
            "name": "[variables('storageAccountName')]",
            "location": "[resourceGroup().location]",
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "supportsHttpsTrafficOnly": true,
                "minimumTlsVersion": "TLS1_2"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/tableServices",
            "apiVersion": "2023-05-01",
            "name": "[concat(variables('storageAccountName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
            ]
        },
        {
            "type": "Microsoft.Storage/storageAccounts/tableServices/tables",
            "apiVersion": "2023-05-01",
            "name": "[concat(variables('storageAccountName'), '/default/', variables('tableName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/tableServices', variables('storageAccountName'), 'default')]"
            ]
        },
        {
            "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
            "apiVersion": "2023-01-31",
            "name": "[variables('managedIdentityName')]",
            "location": "[resourceGroup().location]"
        },
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2023-12-01",
            "name": "[variables('hostingPlanName')]",
            "location": "[resourceGroup().location]",
            "sku": {
                "name": "Y1",
                "tier": "Dynamic"
            },
            "kind": "functionapp",
            "properties": {
                "reserved": true
            }
        },
        {
            "type": "Microsoft.Insights/components",
            "apiVersion": "2020-02-02",
            "name": "[variables('appInsightsName')]",
            "location": "[resourceGroup().location]",
            "kind": "web",
            "properties": {
                "Application_Type": "web",
                "RetentionInDays": 30
            }
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2023-12-01",
            "name": "[variables('functionAppName')]",
            "location": "[resourceGroup().location]",
            "kind": "functionapp,linux",
            "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                    "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]": {}
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]",
                "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts/tableServices/tables', variables('storageAccountName'), 'default', variables('tableName'))]",
                "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
            ],
            "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]",
                "httpsOnly": true,
                "siteConfig": {
                    "linuxFxVersion": "Python|3.11",
                    "appSettings": [
                        {
                            "name": "AzureWebJobsStorage",
                            "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value, ';EndpointSuffix=core.windows.net')]"
                        },
                        {
                            "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
                            "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value, ';EndpointSuffix=core.windows.net')]"
                        },
                        {
                            "name": "WEBSITE_CONTENTSHARE",
                            "value": "[variables('functionAppName')]"
                        },
                        {
                            "name": "FUNCTIONS_EXTENSION_VERSION",
                            "value": "~4"
                        },
                        {
                            "name": "FUNCTIONS_WORKER_RUNTIME",
                            "value": "python"
                        },
                        {
                            "name": "AzureWebJobsFeatureFlags",
                            "value": "EnableWorkerIndexing"
                        },
                        {
                            "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                            "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
                        },
                        {
                            "name": "WEBSITE_RUN_FROM_PACKAGE",
                            "value": "https://github.com/orcunsami/SOCRadar-Azure-Entra-ID/releases/download/v1.0.0/FunctionApp.zip"
                        },
                        {
                            "name": "POLLING_SCHEDULE",
                            "value": "[variables('pollingSchedule')]"
                        },
                        {
                            "name": "SOCRADAR_API_KEY",
                            "value": "[parameters('SocradarApiKey')]"
                        },
                        {
                            "name": "SOCRADAR_COMPANY_ID",
                            "value": "[parameters('SocradarCompanyId')]"
                        },
                        {
                            "name": "ENTRA_TENANT_ID",
                            "value": "[parameters('EntraIdTenantId')]"
                        },
                        {
                            "name": "ENTRA_CLIENT_ID",
                            "value": "[parameters('EntraIdClientId')]"
                        },
                        {
                            "name": "ENTRA_CLIENT_SECRET",
                            "value": "[parameters('EntraIdClientSecret')]"
                        },
                        {
                            "name": "SECURITY_GROUP_ID",
                            "value": "[parameters('SecurityGroupId')]"
                        },
                        {
                            "name": "ENABLE_BOTNET_SOURCE",
                            "value": "[string(parameters('EnableBotnetSource'))]"
                        },
                        {
                            "name": "ENABLE_PII_SOURCE",
                            "value": "[string(parameters('EnablePiiSource'))]"
                        },
                        {
                            "name": "ENABLE_VIP_SOURCE",
                            "value": "[string(parameters('EnableVipSource'))]"
                        },
                        {
                            "name": "ENABLE_REVOKE_SESSION",
                            "value": "[string(parameters('EnableRevokeSession'))]"
                        },
                        {
                            "name": "ENABLE_ADD_TO_GROUP",
                            "value": "[string(parameters('EnableAddToGroup'))]"
                        },
                        {
                            "name": "ENABLE_PASSWORD_CHANGE",
                            "value": "[string(parameters('EnablePasswordChange'))]"
                        },
                        {
                            "name": "ENABLE_DISABLE_ACCOUNT",
                            "value": "[string(parameters('EnableDisableAccount'))]"
                        },
                        {
                            "name": "ENABLE_CONFIRM_RISKY",
                            "value": "[string(parameters('EnableConfirmRisky'))]"
                        },
                        {
                            "name": "ENABLE_ROPC",
                            "value": "[string(parameters('EnableROPC'))]"
                        },
                        {
                            "name": "ENABLE_CREATE_INCIDENT",
                            "value": "[string(parameters('EnableCreateIncident'))]"
                        },
                        {
                            "name": "ENABLE_RESOLVE_ALARM",
                            "value": "[string(parameters('EnableResolveAlarm'))]"
                        },
                        {
                            "name": "ENABLE_LOG_PLAINTEXT_PASSWORD",
                            "value": "[string(parameters('EnableLogPlaintextPassword'))]"
                        },
                        {
                            "name": "INITIAL_LOOKBACK_MINUTES",
                            "value": "[string(parameters('InitialLookbackMinutes'))]"
                        },
                        {
                            "name": "WORKSPACE_ID",
                            "value": "[reference(variables('workspaceResourceId'), '2023-09-01').customerId]"
                        },
                        {
                            "name": "WORKSPACE_KEY",
                            "value": "[listKeys(variables('workspaceResourceId'), '2023-09-01').primarySharedKey]"
                        },
                        {
                            "name": "WORKSPACE_NAME",
                            "value": "[parameters('WorkspaceName')]"
                        },
                        {
                            "name": "WORKSPACE_LOCATION",
                            "value": "[parameters('WorkspaceLocation')]"
                        },
                        {
                            "name": "WORKSPACE_RESOURCE_GROUP",
                            "value": "[if(empty(parameters('WorkspaceResourceGroup')), resourceGroup().name, parameters('WorkspaceResourceGroup'))]"
                        },
                        {
                            "name": "SUBSCRIPTION_ID",
                            "value": "[subscription().subscriptionId]"
                        },
                        {
                            "name": "STORAGE_ACCOUNT_NAME",
                            "value": "[variables('storageAccountName')]"
                        },
                        {
                            "name": "AZURE_CLIENT_ID",
                            "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName')), '2023-01-31').clientId]"
                        }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), variables('managedIdentityName'), variables('StorageTableDataContributorRoleId'))]",
            "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
            ],
            "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('StorageTableDataContributorRoleId'))]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName')), '2023-01-31').principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceId('Microsoft.Web/sites', variables('functionAppName')), variables('managedIdentityName'), variables('WebsiteContributorRoleId'))]",
            "scope": "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]",
                "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]"
            ],
            "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('WebsiteContributorRoleId'))]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName')), '2023-01-31').principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.Resources/deploymentScripts",
            "apiVersion": "2020-10-01",
            "name": "[concat('triggerFirstRun-', uniqueString(resourceGroup().id))]",
            "location": "[resourceGroup().location]",
            "kind": "AzureCLI",
            "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                    "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]": {}
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
                "[guid(resourceId('Microsoft.Web/sites', variables('functionAppName')), variables('managedIdentityName'), variables('WebsiteContributorRoleId'))]"
            ],
            "properties": {
                "azCliVersion": "2.50.0",
                "retentionInterval": "PT1H",
                "timeout": "PT5M",
                "scriptContent": "sleep 30 && az functionapp restart --name $FA_NAME --resource-group $RG_NAME && echo 'Function App restarted'",
                "environmentVariables": [
                    {
                        "name": "FA_NAME",
                        "value": "[variables('functionAppName')]"
                    },
                    {
                        "name": "RG_NAME",
                        "value": "[resourceGroup().name]"
                    }
                ]
            }
        }
    ],
    "outputs": {
        "functionAppName": {
            "type": "string",
            "value": "[variables('functionAppName')]"
        },
        "storageAccountName": {
            "type": "string",
            "value": "[variables('storageAccountName')]"
        },
        "pollingSchedule": {
            "type": "string",
            "value": "[variables('pollingSchedule')]"
        }
    }
}
