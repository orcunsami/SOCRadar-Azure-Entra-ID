        <mxCell id="subtitle3" value="Three-column status board: what is shipped (left), what needs admin action (middle), what awaits your decision (right)." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
