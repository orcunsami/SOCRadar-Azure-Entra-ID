  <diagram name="2. Runtime Flow" id="runtime">
    <mxGraphModel dx="1400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title2" value="One Timer Tick — End-to-End Flow" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle2" value="Top-down. Diamonds are branches. Process rectangles fill the outer loop (per source) and inner loop (per leaked employee)." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1120" height="24" as="geometry" />
        </mxCell>
        <mxCell id="n1" value="&lt;b&gt;TIMER fires&lt;/b&gt;&#xa;every 6 hours · run_on_startup = true" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="460" y="110" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="&lt;b&gt;config.load()&lt;/b&gt;&#xa;Read all ENABLE_* toggles + secrets from app settings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="&lt;b&gt;_required_graph_permissions(conf)&lt;/b&gt;&#xa;Log which Graph permissions are expected based on toggles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="330" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="&lt;b&gt;ENABLE_USER_LOOKUP?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="420" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n5a" value="&lt;b&gt;FALSE branch&lt;/b&gt;&#xa;• Skip MSAL token&#xa;• Skip all Entra actions&#xa;• Still fetch SOCRadar sources&#xa;• Still write LAW audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="440" width="320" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n5b" value="&lt;b&gt;TRUE branch&lt;/b&gt;&#xa;• MSAL: POST /{tenant}/oauth2/v2.0/token&#xa;• Returns access_token (60m TTL)&#xa;• graph_headers = {Authorization: Bearer ...}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="440" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n6" value="&lt;b&gt;OUTER LOOP — for source in [botnet, pii, vip]&lt;/b&gt;" style="shape=process;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="600" width="560" height="56" as="geometry" />
        </mxCell>
        <mxCell id="n7" value="&lt;b&gt;Checkpoint: GET&lt;/b&gt;&#xa;Table Storage → last_start_date, last_page" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="690" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n8" value="&lt;b&gt;SOCRadar: GET leaks&lt;/b&gt;&#xa;[{email, password, severity, ...}]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="690" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n9" value="&lt;b&gt;Checkpoint: PATCH&lt;/b&gt;&#xa;Table Storage ← new last_start_date/page" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="690" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n10" value="&lt;b&gt;INNER LOOP — for emp in leaked_users&lt;/b&gt;" style="shape=process;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="800" width="560" height="56" as="geometry" />
        </mxCell>
        <mxCell id="n11" value="&lt;b&gt;Graph: GET /users/{email}&lt;/b&gt;&#xa;200 = found · 404 = not_found · 403 = permission denied" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="890" width="560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n12" value="&lt;b&gt;Action chain (each toggle-gated)&lt;/b&gt;&#xa;&#xa;1. enable_revoke_session → POST /revokeSignInSessions&#xa;2. enable_add_to_group → POST /groups/{gid}/members/$ref&#xa;3. enable_remove_from_group → DELETE members/{id}/$ref&#xa;4. enable_disable_account → PATCH accountEnabled = false&#xa;5. enable_enable_account → PATCH accountEnabled = true&#xa;6. enable_password_change → PATCH passwordProfile&#xa;7. enable_confirm_risky → POST /riskyUsers/confirmCompromised  [needs P1/P2]&#xa;8. ⭐ enable_force_mfa_reregistration (NEW) → GET + DELETE auth methods&#xa;9. enable_ropc → validate password via ROPC (if plaintext, discouraged)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="990" width="800" height="230" as="geometry" />
        </mxCell>
        <mxCell id="n13" value="&lt;b&gt;LAW: POST SOCRadar_{source}_CL&lt;/b&gt;&#xa;One record per employee, includes actions_taken[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="1260" width="560" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n14" value="Optional: Sentinel PUT /incidents/{guid}&#xa;Optional: SOCRadar POST /alarms/{id}/resolve" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffffff;strokeColor=#666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="1350" width="560" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n15" value="&lt;b&gt;END of tick&lt;/b&gt;&#xa;LAW: POST SOCRadar_EntraID_Audit_CL (3 rows)&#xa;Total: 1–32 seconds" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="1440" width="440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n1" target="n2">
          <mxGeometry relative="1" as="geometry" />
