  <diagram name="1. Architecture" id="architecture">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" value="SOCRadar Entra ID — Architecture" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Hub-and-spoke: Function App is the central orchestrator. External services on the left. Customer Azure resources on the right." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="ext_grp" value="EXTERNAL SERVICES" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="440" height="900" as="geometry" />
        </mxCell>
        <mxCell id="socr" value="&lt;b&gt;SOCRadar Platform API&lt;/b&gt;&#xa;platform.socradar.com&#xa;&#xa;GET /botnet&#xa;GET /pii&#xa;GET /vip&#xa;POST /alarm/resolve&#xa;&#xa;Auth: X-Api-Key header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="login" value="&lt;b&gt;login.microsoftonline.com&lt;/b&gt;&#xa;&#xa;POST /{tenant}/oauth2/v2.0/token&#xa;scope: graph.microsoft.com/.default&#xa;grant_type: client_credentials&#xa;&#xa;Returns: access_token (60m TTL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="graph" value="&lt;b&gt;Microsoft Graph API v1.0&lt;/b&gt;&#xa;graph.microsoft.com&#xa;&#xa;GET  /users/{email}&#xa;POST /users/{id}/revokeSignInSessions&#xa;POST /groups/{gid}/members/$ref&#xa;PATCH /users/{id}&#xa;POST /riskyUsers/confirmCompromised&#xa;GET  /users/{id}/authentication/methods&#xa;DELETE /users/{id}/authentication/.../{mid}&#xa;&#xa;Auth: Bearer access_token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="620" width="360" height="260" as="geometry" />
        </mxCell>
        <mxCell id="az_grp" value="CUSTOMER AZURE SUBSCRIPTION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="640" y="110" width="1120" height="900" as="geometry" />
        </mxCell>
        <mxCell id="fa" value="&lt;b&gt;⚡ Azure Function App&lt;/b&gt;&#xa;socradar-entraid-xxx&#xa;&#xa;Python 3.11 / Consumption&#xa;Timer trigger (every 6h)&#xa;run_on_startup = true&#xa;&#xa;• function_app.py — entry point&#xa;• actions/* — Graph, Sentinel, LAW&#xa;• sources/* — SOCRadar fetch&#xa;• utils/* — config, checkpoint, logging" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=0;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="400" width="320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="uami" value="&lt;b&gt;🔑 User-Assigned&lt;/b&gt;&#xa;&lt;b&gt;Managed Identity&lt;/b&gt;&#xa;&#xa;DefaultAzureCredential&#xa;(AZURE_CLIENT_ID env)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="160" width="260" height="120" as="geometry" />
        </mxCell>
        <mxCell id="stor" value="&lt;b&gt;💾 Storage Account&lt;/b&gt;&#xa;&#xa;Table: EntraIDState&#xa;PartitionKey = source&#xa;RowKey = checkpoint&#xa;&#xa;Fields:&#xa;• last_start_date&#xa;• last_page" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=18;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=18;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="340" width="260" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ai" value="&lt;b&gt;📊 Application Insights&lt;/b&gt;&#xa;&#xa;traces / requests /&#xa;exceptions / metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1440" y="160" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="law" value="&lt;b&gt;📋 Log Analytics Workspace&lt;/b&gt;&#xa;&#xa;HTTP Data Collector API&#xa;HMAC-signed POST&#xa;&#xa;Custom tables:&#xa;• SOCRadar_Botnet_CL&#xa;• SOCRadar_PII_CL&#xa;• SOCRadar_VIP_CL&#xa;• SOCRadar_Identity_CL&#xa;• SOCRadar_EntraID_Audit_CL" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=18;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=18;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="700" width="360" height="240" as="geometry" />
        </mxCell>
        <mxCell id="sent" value="&lt;b&gt;🚨 Microsoft Sentinel&lt;/b&gt;&#xa;(optional — ENABLE_CREATE_INCIDENT)&#xa;&#xa;PUT .../incidents/{guid}&#xa;?api-version=2024-03-01&#xa;&#xa;Flows to SecurityIncident table in LAW" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="700" width="360" height="180" as="geometry" />
