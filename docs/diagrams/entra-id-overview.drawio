        <mxCell id="socr" value="SOCRadar Platform API&#xa;platform.socradar.com&#xa;&#xa;GET /api/company/330/v2/threat-feed/search/botnet&#xa;GET /api/company/330/v2/incident/pii&#xa;GET /api/company/330/v2/incident/vip-protection&#xa;POST /api/company/330/incident/alarms/{id}/resolve&#xa;&#xa;Auth: X-Api-Key header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
