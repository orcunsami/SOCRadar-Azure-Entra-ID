        <mxCell id="r16_2" value="LOG_PLAINTEXT_PASSWORD" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="90" y="1005" width="360" height="50" as="geometry" />
