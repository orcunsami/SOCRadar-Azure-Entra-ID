        <mxCell id="r14_4" value="Create Microsoft Sentinel incident per compromised user (PUT /incidents/{guid})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="875" width="640" height="40" as="geometry" />
