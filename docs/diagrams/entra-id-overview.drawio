        <mxCell id="r16_5" value="None (policy flag only). Off by default." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="1005" width="580" height="50" as="geometry" />
        </mxCell>
        <mxCell id="foot3" value="&lt;b&gt;Required app settings (not toggles)&lt;/b&gt;: SOCRADAR_API_KEY, SOCRADAR_COMPANY_ID, WORKSPACE_ID, WORKSPACE_KEY, STORAGE_ACCOUNT_NAME, POLLING_INTERVAL_HOURS, INITIAL_LOOKBACK_MINUTES. ENTRA_* needed only when USER_LOOKUP=true." style="text;strokeColor=none;fillColor=none;html=1;fontSize=12;align=center;fontColor=#555;fontStyle=2;" vertex="1" parent="1">
