        <mxCell id="r14_5" value="management.azure.com role on Sentinel workspace (separate from Graph perms)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
