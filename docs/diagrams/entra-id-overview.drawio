  <diagram name="2. Runtime Flow" id="runtime">
    <mxGraphModel dx="1400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t2" value="Runtime Flow — One Timer Tick (every 6h)" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t2s" value="Top-down. Diamonds = branch. Process rectangles = loop. Typical duration 1–32 seconds." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1120" height="24" as="geometry" />
        </mxCell>
        <mxCell id="r1" value="&lt;b&gt;TIMER fires&lt;/b&gt;&#xa;every 6 hours · run_on_startup=true" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="460" y="110" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="&lt;b&gt;config.load()&lt;/b&gt;&#xa;Read all ENABLE_* toggles + secrets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r3" value="&lt;b&gt;_required_graph_permissions()&lt;/b&gt;&#xa;Log which Graph permissions are expected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="330" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r4" value="&lt;b&gt;ENABLE_USER_LOOKUP?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="420" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r5a" value="&lt;b&gt;FALSE&lt;/b&gt;&#xa;• Skip MSAL token&#xa;• Skip all Entra actions&#xa;• Still fetch SOCRadar sources&#xa;• Still write LAW audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="440" width="320" height="110" as="geometry" />
        </mxCell>
        <mxCell id="r5b" value="&lt;b&gt;TRUE&lt;/b&gt;&#xa;• MSAL: POST /{tenant}/oauth2/v2.0/token&#xa;• Returns access_token (60m TTL)&#xa;• Consent check: ConsentRevokedError catches AADSTS&#xa;• Write consent_revoked audit event if failed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="440" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="r6" value="&lt;b&gt;OUTER LOOP — for source in [botnet, pii, vip]&lt;/b&gt;" style="shape=process;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="600" width="560" height="56" as="geometry" />
        </mxCell>
        <mxCell id="r7" value="&lt;b&gt;Checkpoint: GET&lt;/b&gt;&#xa;Table Storage → last_start_date, last_page" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="690" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r8" value="&lt;b&gt;SOCRadar: GET leaks&lt;/b&gt;&#xa;[{email, password, severity, ...}]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="690" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r9" value="&lt;b&gt;Checkpoint: PATCH&lt;/b&gt;&#xa;Table Storage ← new start_date/page" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="690" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r10" value="&lt;b&gt;INNER LOOP — for emp in leaked_users&lt;/b&gt;" style="shape=process;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="800" width="560" height="56" as="geometry" />
        </mxCell>
        <mxCell id="r11" value="&lt;b&gt;Graph: GET /users/{email}&lt;/b&gt;  (with retry 429 wrapper)&#xa;200=found · 404=not_found · 403=permission_denied" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="890" width="560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r12" value="&lt;b&gt;Action chain (each toggle-gated, retry wrapper on all)&lt;/b&gt;&#xa;&#xa;1. enable_revoke_session → POST /revokeSignInSessions&#xa;2. enable_add_to_group → POST /groups/{gid}/members/$ref&#xa;3. enable_remove_from_group → DELETE members/{id}/$ref&#xa;4. enable_disable_account → PATCH accountEnabled=false&#xa;5. enable_enable_account → PATCH accountEnabled=true&#xa;6. enable_password_change → PATCH passwordProfile&#xa;7. enable_confirm_risky → POST /riskyUsers/confirmCompromised  [P1/P2]&#xa;8. ⭐ enable_force_mfa_reregistration → GET + DELETE auth methods&#xa;9. enable_ropc → validate password via ROPC (if plaintext, discouraged)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="990" width="800" height="230" as="geometry" />
        </mxCell>
        <mxCell id="r13" value="&lt;b&gt;LAW: POST SOCRadar_{source}_CL&lt;/b&gt;&#xa;One record per employee, includes actions_taken[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="1260" width="560" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r14" value="Optional: Sentinel PUT /incidents/{guid}&#xa;Optional: SOCRadar POST /alarms/{id}/resolve" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffffff;strokeColor=#666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="1350" width="560" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r15" value="&lt;b&gt;END of tick&lt;/b&gt;&#xa;LAW: POST SOCRadar_EntraID_Audit_CL (3 rows per source)&#xa;Total: 1–32 seconds" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="1440" width="440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="rf1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r1" target="r2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r2" target="r3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r3" target="r4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf4" value="false" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#b85450;fontSize=11;fontStyle=1;" edge="1" parent="1" source="r4" target="r5a"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf5" value="true" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;fontSize=11;fontStyle=1;" edge="1" parent="1" source="r4" target="r5b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r5a" target="r6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r5b" target="r6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#9673a6;" edge="1" parent="1" source="r6" target="r7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#9673a6;" edge="1" parent="1" source="r6" target="r8"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#9673a6;" edge="1" parent="1" source="r6" target="r9"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r8" target="r10"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r10" target="r11"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r11" target="r12"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r12" target="r13"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#666;dashed=1;" edge="1" parent="1" source="r13" target="r14"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rf16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="r14" target="r15"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="3. Feature Matrix" id="features">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="tf" value="Feature Matrix — Every ENABLE_* toggle" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tfs" value="Three columns: Sources (what to ingest) · Actions (what to do on matched users) · Output (where alerts go). Every toggle can be independently on/off." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="srcgrp" value="① SOURCES — what to fetch from SOCRadar" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="560" height="1060" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;ENABLE_BOTNET_SOURCE&lt;/b&gt;  (default: true)&#xa;&#xa;Fetches leaked credentials detected on&#xa;botnet infrastructure (stealer logs).&#xa;&#xa;API: GET /threat-feed/search/botnet&#xa;Writes: SOCRadar_Botnet_CL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="520" height="160" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;ENABLE_PII_SOURCE&lt;/b&gt;  (default: true)&#xa;&#xa;Fetches employee credentials detected in&#xa;PII exposure incidents (dark web, breaches).&#xa;&#xa;API: GET /incident/pii&#xa;Writes: SOCRadar_PII_CL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="520" height="160" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;ENABLE_VIP_SOURCE&lt;/b&gt;  (default: false)&#xa;&#xa;Fetches credentials flagged as VIP (executives).&#xa;&#xa;⚠ UNVERIFIED — endpoint not in official API docs.&#xa;Use with caution.&#xa;&#xa;API: GET /incident/vip-protection&#xa;Writes: SOCRadar_VIP_CL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="520" height="180" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="&lt;b&gt;ENABLE_USER_LOOKUP&lt;/b&gt;  (default: true)&#xa;&#xa;MASTER GATE for all Entra actions.&#xa;If false: sources still fetch + LAW writes,&#xa;but Entra lookup and ALL actions are skipped.&#xa;&#xa;Used for data-ingest-only mode.&#xa;Permission: User.Read.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="720" width="520" height="180" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="&lt;b&gt;ENABLE_LOG_PLAINTEXT_PASSWORD&lt;/b&gt;  (default: false)&#xa;&#xa;Password retention policy.&#xa;false = only password_present masked field stored&#xa;true = plaintext password written to LAW (unsafe)&#xa;&#xa;Enable ONLY if security policy explicitly requires." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="920" width="520" height="180" as="geometry" />
        </mxCell>
        <mxCell id="actgrp" value="② ACTIONS — what to do on matched users" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="620" y="110" width="560" height="1060" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="&lt;b&gt;ENABLE_REVOKE_SESSION&lt;/b&gt;  (default: true)&#xa;Kick user out of all signed-in devices.&#xa;Perm: User.RevokeSessions.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="160" width="520" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="&lt;b&gt;ENABLE_ADD_TO_GROUP&lt;/b&gt;  (default: true)&#xa;Add user to a security/quarantine group.&#xa;Perm: GroupMember.ReadWrite.All + SECURITY_GROUP_ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="250" width="520" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="&lt;b&gt;ENABLE_REMOVE_FROM_GROUP&lt;/b&gt;  (default: false)&#xa;Reverse of add. Perm: GroupMember.ReadWrite.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="340" width="520" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="&lt;b&gt;ENABLE_PASSWORD_CHANGE&lt;/b&gt;  (default: false)&#xa;Force password change at next sign-in.&#xa;Perm: User-PasswordProfile.ReadWrite.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="420" width="520" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a5" value="&lt;b&gt;ENABLE_DISABLE_ACCOUNT&lt;/b&gt;  (default: false)&#xa;Disable user account.&#xa;Perm: User.EnableDisableAccount.All.  HIGH IMPACT." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="510" width="520" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a6" value="&lt;b&gt;ENABLE_ENABLE_ACCOUNT&lt;/b&gt;  (default: false)&#xa;Re-enable previously disabled accounts.&#xa;Perm: User.EnableDisableAccount.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="600" width="520" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a7" value="&lt;b&gt;ENABLE_CONFIRM_RISKY&lt;/b&gt;  (default: false)&#xa;Flag user as compromised. Customer's CA policy takes over.&#xa;Perm: IdentityRiskyUser.ReadWrite.All + Entra P1/P2 license" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="690" width="520" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a8" value="&lt;b&gt;⭐ ENABLE_FORCE_MFA_REREGISTRATION&lt;/b&gt;  (default: false)&#xa;Delete ALL non-password auth methods (Authenticator,&#xa;phone, FIDO2, etc) → user re-registers MFA at next sign-in.&#xa;Perm: UserAuthenticationMethod.ReadWrite.All + PrivAuthAdmin role&#xa;HIGHEST IMPACT — works on every Entra tier" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="780" width="520" height="130" as="geometry" />
        </mxCell>
        <mxCell id="a9" value="&lt;b&gt;ENABLE_ROPC&lt;/b&gt;  (default: false)&#xa;Validate leaked password via ROPC (does it still work?).&#xa;Only with plaintext. Microsoft discourages in production.&#xa;Requires 'Allow public client flows' on App Registration." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="930" width="520" height="120" as="geometry" />
        </mxCell>
        <mxCell id="a_note" value="⚠ ALL actions above require ENABLE_USER_LOOKUP=true as master gate." style="text;strokeColor=none;fillColor=none;html=1;fontSize=11;align=center;fontColor=#b85450;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="640" y="1070" width="520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="outgrp" value="③ OUTPUT — where alerts go" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="1200" y="110" width="560" height="1060" as="geometry" />
        </mxCell>
        <mxCell id="o1" value="&lt;b&gt;ENABLE_CREATE_INCIDENT&lt;/b&gt;  (default: false)&#xa;&#xa;Create a Microsoft Sentinel incident for each&#xa;compromised user detected.&#xa;&#xa;Endpoint: PUT .../providers/Microsoft.SecurityInsights/&#xa;          incidents/{guid}?api-version=2024-03-01&#xa;&#xa;Auth: management.azure.com token (separate from Graph)&#xa;&#xa;Requires: WORKSPACE_NAME + WORKSPACE_RESOURCE_GROUP set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="160" width="520" height="230" as="geometry" />
        </mxCell>
        <mxCell id="o2" value="&lt;b&gt;ENABLE_RESOLVE_ALARM&lt;/b&gt;  (default: false)&#xa;&#xa;When a leak-matched user is found in Entra and&#xa;actions are applied successfully, auto-resolve the&#xa;originating SOCRadar alarm (optional closed-loop).&#xa;&#xa;Endpoint: POST /incident/alarms/{id}/resolve&#xa;&#xa;Helps SOC avoid manual alarm triage for auto-remediated&#xa;cases." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="410" width="520" height="210" as="geometry" />
        </mxCell>
        <mxCell id="o3" value="&lt;b&gt;Always-on outputs (no toggle)&lt;/b&gt;&#xa;&#xa;• SOCRadar_{source}_CL — per-employee record&#xa;  Fields: email, severity, actions_taken, entra_status,&#xa;          mfa_methods_deleted, timestamp&#xa;&#xa;• SOCRadar_EntraID_Audit_CL — per-source summary&#xa;  Fields: source, total, found, not_found, actions,&#xa;          errors, duration_sec, timestamp&#xa;&#xa;• SOCRadar_EntraID_Audit_CL — lifecycle events (NEW)&#xa;  event_type: consent_revoked, token_acquisition_failed&#xa;  Used for alerting on auth breakage&#xa;&#xa;• Application Insights — all traces, exceptions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="640" width="520" height="360" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="4. MSSP Setup" id="msspsetup">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="tms" value="MSSP — One-Time Setup Flow" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tmsb" value="A (MSSP) manages X and Y. A deploys the integration in its own Azure. X and Y admins click a consent link once. Done." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="&lt;b&gt;STEP 1 — A deploys integration (in A's Azure subscription)&lt;/b&gt;&#xa;&#xa;• ARM template runs → Function App + UAMI + Storage + LAW in A's subscription&#xa;• App Registration created in A's tenant with signInAudience = AzureADMultipleOrgs (multi-tenant)&#xa;• This step = today's single-tenant deploy + ONE extra line: signInAudience switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="1720" height="130" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;STEP 2 — A sends consent URLs to customer admins&lt;/b&gt;&#xa;&#xa;A generates per-tenant URLs:&#xa;https://login.microsoftonline.com/{X_TENANT_ID}/adminconsent?client_id={A_APP_ID}&#xa;https://login.microsoftonline.com/{Y_TENANT_ID}/adminconsent?client_id={A_APP_ID}&#xa;&#xa;Sends to X's BT yöneticisi and Y's BT yöneticisi by email." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="1720" height="170" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;STEP 3 — X and Y admins click their link (once, in their own browser)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="atenant" value="&lt;b&gt;A's Tenant&lt;/b&gt;&#xa;(MSSP home)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="510" width="540" height="300" as="geometry" />
        </mxCell>
        <mxCell id="aapp" value="App Registration&#xa;(signInAudience:&#xa; AzureADMultipleOrgs)&#xa;&#xa;appId = b0afca82-...&#xa;&#xa;Service Principal in A's tenant&#xa;→ full configured permissions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="560" width="480" height="230" as="geometry" />
        </mxCell>
        <mxCell id="xtenant" value="&lt;b&gt;X's Tenant&lt;/b&gt;&#xa;(customer)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="620" y="510" width="540" height="300" as="geometry" />
        </mxCell>
        <mxCell id="xapp" value="X admin clicks consent URL →&#xa;Microsoft creates NEW&#xa;Service Principal in X's tenant&#xa;for appId b0afca82-...&#xa;&#xa;X's SP has SAME permissions&#xa;as A's SP (User.Read.All,&#xa;User.RevokeSessions.All, ...)&#xa;but scoped to X's directory only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="650" y="560" width="480" height="230" as="geometry" />
        </mxCell>
        <mxCell id="ytenant" value="&lt;b&gt;Y's Tenant&lt;/b&gt;&#xa;(customer)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1200" y="510" width="540" height="300" as="geometry" />
        </mxCell>
        <mxCell id="yapp" value="Y admin clicks consent URL →&#xa;Microsoft creates NEW&#xa;Service Principal in Y's tenant&#xa;for appId b0afca82-...&#xa;&#xa;Y's SP scoped to Y's directory only.&#xa;&#xa;If Y revokes consent → A's app&#xa;gets 401 when trying to token for Y.&#xa;G3 consent_revoked event fires." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1230" y="560" width="480" height="230" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="&lt;b&gt;STEP 4 — A adds tenant mapping to Function App config&lt;/b&gt;&#xa;&#xa;Function App env var:&#xa;TENANT_MAPPING = [&#xa;  {&quot;domain&quot;: &quot;acme.com&quot;, &quot;tenantId&quot;: &quot;{A_TID}&quot;},&#xa;  {&quot;domain&quot;: &quot;xholding.com&quot;, &quot;tenantId&quot;: &quot;{X_TID}&quot;},&#xa;  {&quot;domain&quot;: &quot;y-insaat.com&quot;, &quot;tenantId&quot;: &quot;{Y_TID}&quot;}&#xa;]&#xa;&#xa;Now runtime can route each leak to the correct tenant based on email domain." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="840" width="1720" height="220" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="✅ Setup complete. Runtime flow (next page) handles per-tenant routing automatically." style="text;strokeColor=none;fillColor=none;html=1;fontSize=14;align=center;fontStyle=1;fontColor=#2d7d32;" vertex="1" parent="1">
          <mxGeometry x="40" y="1080" width="1720" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="5. MSSP Runtime" id="mssprun">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="tmr" value="MSSP — Runtime Flow Per Leak" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tmrs" value="One timer tick pulls leaks from one SOCRadar API. Each leak is routed by email domain to the correct Entra tenant. Function App caches one token per tenant." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="socr2" value="&lt;b&gt;SOCRadar API&lt;/b&gt;&#xa;(A's single account)&#xa;&#xa;Returns leaks:&#xa;• john@acme.com&#xa;• alice@xholding.com&#xa;• bob@y-insaat.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="fa2" value="&lt;b&gt;⚡ Function App&lt;/b&gt;&#xa;(in A's subscription)&#xa;&#xa;Step: for each leak, parse domain" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="460" y="140" width="340" height="160" as="geometry" />
        </mxCell>
        <mxCell id="cache" value="&lt;b&gt;_graph_headers_by_tenant (module-level cache)&lt;/b&gt;&#xa;&#xa;{&#xa;  &quot;{A_TID}&quot;: {Bearer A-token (60m)},&#xa;  &quot;{X_TID}&quot;: {Bearer X-token (60m)},&#xa;  &quot;{Y_TID}&quot;: {Bearer Y-token (60m)}&#xa;}&#xa;&#xa;Populated on first call per tenant, reused across the tick." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="110" width="520" height="210" as="geometry" />
        </mxCell>
        <mxCell id="tmap" value="&lt;b&gt;TENANT_MAPPING (env var)&lt;/b&gt;&#xa;&#xa;[&#xa;  {&quot;domain&quot;: &quot;acme.com&quot;, &quot;tenantId&quot;: &quot;{A_TID}&quot;},&#xa;  {&quot;domain&quot;: &quot;xholding.com&quot;, &quot;tenantId&quot;: &quot;{X_TID}&quot;},&#xa;  {&quot;domain&quot;: &quot;y-insaat.com&quot;, &quot;tenantId&quot;: &quot;{Y_TID}&quot;}&#xa;]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1460" y="130" width="300" height="180" as="geometry" />
        </mxCell>
        <mxCell id="divider" value="— PER LEAK PROCESSING —" style="text;strokeColor=none;fillColor=none;html=1;fontSize=14;fontStyle=1;align=center;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="1720" height="30" as="geometry" />
        </mxCell>
        <mxCell id="leakA" value="&lt;b&gt;Leak 1: john@acme.com&lt;/b&gt;&#xa;&#xa;1. domain = &quot;acme.com&quot;&#xa;2. _resolve_tenant_for(domain) → {A_TID}&#xa;3. _acquire_graph_headers_for({A_TID})&#xa;   → token acquired if not cached&#xa;4. GET /users/john@acme.com (A's directory)&#xa;5. If found → apply enabled actions to A's user&#xa;6. LAW record: target_tenant_id = A_TID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="leakX" value="&lt;b&gt;Leak 2: alice@xholding.com&lt;/b&gt;&#xa;&#xa;1. domain = &quot;xholding.com&quot;&#xa;2. _resolve_tenant_for(domain) → {X_TID}&#xa;3. _acquire_graph_headers_for({X_TID})&#xa;   → token acquired against X's tenant&#xa;4. GET /users/alice@xholding.com (X's directory)&#xa;5. If found → apply enabled actions to X's user&#xa;6. LAW record: target_tenant_id = X_TID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="400" width="560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="leakY" value="&lt;b&gt;Leak 3: bob@y-insaat.com&lt;/b&gt;&#xa;&#xa;1. domain = &quot;y-insaat.com&quot;&#xa;2. _resolve_tenant_for(domain) → {Y_TID}&#xa;3. _acquire_graph_headers_for({Y_TID})&#xa;   → token acquired against Y's tenant&#xa;4. GET /users/bob@y-insaat.com (Y's directory)&#xa;5. If found → apply enabled actions to Y's user&#xa;6. LAW record: target_tenant_id = Y_TID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1200" y="400" width="560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="edgeA" value="Test" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="fa2" target="leakA"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edgeX" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="fa2" target="leakX"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edgeY" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="fa2" target="leakY"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edgeSocr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="socr2" target="fa2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edgeSocrL" value="GET leaks (one batch)" style="edgeLabel;html=1;align=center;fontSize=11;fontStyle=1;labelBackgroundColor=#ffffff;" vertex="1" connectable="0" parent="edgeSocr"><mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        <mxCell id="edgeCache" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;startArrow=classic;startFill=1;dashed=1;strokeColor=#9673a6;" edge="1" parent="1" source="fa2" target="cache"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edgeCacheL" value="cache lookup" style="edgeLabel;html=1;align=center;fontSize=11;fontStyle=2;labelBackgroundColor=#ffffff;fontColor=#9673a6;" vertex="1" connectable="0" parent="edgeCache"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        <mxCell id="edgeMap" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;dashed=1;strokeColor=#666;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="tmap" target="cache"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="law2" value="&lt;b&gt;Log Analytics Workspace (in A's subscription)&lt;/b&gt;&#xa;&#xa;All leaks, regardless of target tenant, go to A's LAW.&#xa;The target_tenant_id column lets A's SOC filter by customer:&#xa;&#xa;SOCRadar_Botnet_CL&#xa;| where target_tenant_id == &quot;{X_TID}&quot;&#xa;| project TimeGenerated, email, actions_taken, entra_status" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=18;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=18;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="540" y="680" width="720" height="180" as="geometry" />
        </mxCell>
        <mxCell id="edgeLawA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;" edge="1" parent="1" source="leakA" target="law2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edgeLawX" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;" edge="1" parent="1" source="leakX" target="law2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edgeLawY" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;" edge="1" parent="1" source="leakY" target="law2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="note" value="&lt;b&gt;Edge case: domain NOT in mapping&lt;/b&gt;&#xa;&#xa;Leak email: charlie@unknown-new-client.com&#xa;_resolve_tenant_for(&quot;unknown-new-client.com&quot;) → falls back to ENTRA_TENANT_ID (A's default)&#xa;→ attempts lookup in A's directory → likely 404 → logged as not_found&#xa;&#xa;Recommended: also write a warning audit event so A knows to add the domain to TENANT_MAPPING." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="900" width="1720" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="6. Force MFA Options" id="mfa">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="tmfa" value="Force MFA — 4 Options Compared" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tmfas" value="When a password leaks, you can enforce MFA in four ways. Options are not mutually exclusive — A+C or A+D combinations are common." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="oA" value="&lt;b&gt;OPTION A&lt;/b&gt;&#xa;Delete auth methods&#xa;&#xa;&lt;b&gt;STATUS: ✅ SHIPPED&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="oAd" value="&lt;b&gt;What it does&lt;/b&gt;&#xa;Delete every non-password auth method&#xa;(Authenticator, phone, FIDO2, OATH, WHfB,&#xa; email, TAP). User re-registers at next login.&#xa;&#xa;&lt;b&gt;Permission&lt;/b&gt;&#xa;UserAuthenticationMethod.ReadWrite.All&#xa;+ Privileged Auth Administrator role&#xa;&#xa;&lt;b&gt;Graph version&lt;/b&gt;  v1.0 stable&#xa;&lt;b&gt;License&lt;/b&gt;  ANY (works on Free tier)&#xa;&lt;b&gt;User friction&lt;/b&gt;  HIGH — re-register all&#xa;&lt;b&gt;Reversible&lt;/b&gt;  No (user registers again)&#xa;&lt;b&gt;Ongoing enforcement&lt;/b&gt;  No — one-time reset&#xa;&lt;b&gt;Customer-side config required&lt;/b&gt;  None" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="420" height="440" as="geometry" />
        </mxCell>
        <mxCell id="oB" value="&lt;b&gt;OPTION B&lt;/b&gt;&#xa;perUserMfaState=enforced&#xa;&#xa;&lt;b&gt;STATUS: ❌ REJECTED&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="490" y="110" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="oBd" value="&lt;b&gt;What it does&lt;/b&gt;&#xa;PATCH user's authentication/requirements &#xa;→ force per-user MFA state to 'enforced'.&#xa;User prompted for MFA every sign-in.&#xa;&#xa;&lt;b&gt;Permission&lt;/b&gt;&#xa;Policy.ReadWrite.AuthenticationMethod&#xa;&#xa;&lt;b&gt;Graph version&lt;/b&gt;  BETA ONLY&#xa;&lt;b&gt;License&lt;/b&gt;  ANY&#xa;&lt;b&gt;User friction&lt;/b&gt;  Medium (MFA every login)&#xa;&lt;b&gt;Reversible&lt;/b&gt;  Yes (set back to 'disabled')&#xa;&lt;b&gt;Ongoing enforcement&lt;/b&gt;  Yes&#xa;&lt;b&gt;⚠ Why rejected:&lt;/b&gt;  Microsoft discourages beta&#xa;endpoints in production + per-user MFA is&#xa;legacy (MS pushes Conditional Access)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="490" y="210" width="420" height="440" as="geometry" />
        </mxCell>
        <mxCell id="oC" value="&lt;b&gt;OPTION C&lt;/b&gt;&#xa;Confirm Risky (existing)&#xa;&#xa;&lt;b&gt;STATUS: ✅ SHIPPED&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="940" y="110" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="oCd" value="&lt;b&gt;What it does&lt;/b&gt;&#xa;POST /riskyUsers/confirmCompromised&#xa;Flags user as compromised. Customer's&#xa;Conditional Access policy (if any) takes over&#xa;and enforces MFA or blocks.&#xa;&#xa;&lt;b&gt;Permission&lt;/b&gt;&#xa;IdentityRiskyUser.ReadWrite.All&#xa;&#xa;&lt;b&gt;Graph version&lt;/b&gt;  v1.0 stable&#xa;&lt;b&gt;License&lt;/b&gt;  Entra P1 or P2 required&#xa;&lt;b&gt;User friction&lt;/b&gt;  Low (depends on CA policy)&#xa;&lt;b&gt;Reversible&lt;/b&gt;  Yes (dismiss)&#xa;&lt;b&gt;Ongoing enforcement&lt;/b&gt;  Yes (while flagged)&#xa;&lt;b&gt;Customer-side config required&lt;/b&gt;  CA policy&#xa;targeting risky users must exist&#xa;&#xa;&lt;b&gt;MS recommendation:&lt;/b&gt;  ⭐ Preferred path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="210" width="420" height="440" as="geometry" />
        </mxCell>
        <mxCell id="oD" value="&lt;b&gt;OPTION D&lt;/b&gt;&#xa;Programmatic CA policy&#xa;&#xa;&lt;b&gt;STATUS: 📋 PROPOSED&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1390" y="110" width="370" height="90" as="geometry" />
        </mxCell>
        <mxCell id="oDd" value="&lt;b&gt;What it does&lt;/b&gt;&#xa;POST /identity/conditionalAccess/policies&#xa;Create a targeted policy for THIS user:&#xa;&quot;when X signs in, require MFA&quot; or block.&#xa;Less destructive than A, more specific than C.&#xa;&#xa;&lt;b&gt;Permission&lt;/b&gt;&#xa;Policy.ReadWrite.ConditionalAccess&#xa;&#xa;&lt;b&gt;Graph version&lt;/b&gt;  v1.0 stable&#xa;&lt;b&gt;License&lt;/b&gt;  Entra P1 or P2 required&#xa;&lt;b&gt;User friction&lt;/b&gt;  Low (normal MFA prompt)&#xa;&lt;b&gt;Reversible&lt;/b&gt;  Yes (DELETE policy)&#xa;&lt;b&gt;Ongoing enforcement&lt;/b&gt;  Yes (until deleted)&#xa;&lt;b&gt;Customer-side config required&lt;/b&gt;  None&#xa;&#xa;&lt;b&gt;Complements A:&lt;/b&gt;&#xa;• P1/P2 customers use D (gentle)&#xa;• Free-tier customers use A (harder)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1390" y="210" width="370" height="440" as="geometry" />
        </mxCell>
        <mxCell id="guide" value="&lt;b&gt;Which option to enable for a given customer&lt;/b&gt;&#xa;&#xa;🏢 &lt;b&gt;Enterprise customer with Entra P1/P2 + existing CA policy:&lt;/b&gt;  Option C alone. Soft, MS-recommended, ongoing.&#xa;&#xa;🏢 &lt;b&gt;Enterprise customer with P1/P2 but no CA policy:&lt;/b&gt;  Option D (create scoped policy per compromised user) + optionally C.&#xa;&#xa;🏠 &lt;b&gt;Small customer on Free tier:&lt;/b&gt;  Option A (Force MFA Re-registration). Only option that works without P1/P2.&#xa;&#xa;🔒 &lt;b&gt;High-severity / VIP compromise (any tier):&lt;/b&gt;  Option A + disable_account (kills session + locks out + forces re-register).&#xa;&#xa;⚠ Option B is intentionally excluded from the platform." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="1720" height="220" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="7. Distribution" id="dist">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="td" value="Distribution — How Customers Install" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tds" value="Two paths today. One is live, the other requires Microsoft certification." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="path1" value="&lt;b&gt;① ARM Button (available today, ✅)&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="860" height="810" as="geometry" />
        </mxCell>
        <mxCell id="p1a" value="&lt;b&gt;Where customer finds it&lt;/b&gt;&#xa;README.md on GitHub → &quot;Deploy to Azure&quot; button&#xa;https://github.com/orcunsami/SOCRadar-Azure-Entra-ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="820" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p1b" value="&lt;b&gt;What happens&lt;/b&gt;&#xa;1. Click button → Azure portal opens with ARM template&#xa;2. Customer fills parameters: SOCRadar key, tenant_id, workspace, etc.&#xa;3. Click Create → Azure deploys Function App + Storage + UAMI + (optional) Sentinel wiring&#xa;4. Function App downloads code from WEBSITE_RUN_FROM_PACKAGE URL (our v1.1.0 release zip)&#xa;5. Timer starts automatically, first run in 3 minutes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="820" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1pros" value="&lt;b&gt;Pros&lt;/b&gt;&#xa;• Live today, no certification needed&#xa;• Full control over release cadence&#xa;• No review gatekeeper&#xa;• One-click install for technical customers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="400" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p1cons" value="&lt;b&gt;Cons&lt;/b&gt;&#xa;• Customer lands on &quot;random GitHub repo&quot;&#xa;• BT güvenliği sometimes blocks this flow&#xa;• No Microsoft trust stamp&#xa;• No update notification in Sentinel&#xa;• Not discoverable via search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="490" width="400" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p1status" value="&lt;b&gt;Current status&lt;/b&gt;&#xa;✅ Works (fixed ARM URL to v1.1.0 this session)&#xa;✅ Auto-release workflow in place for future versions&#xa;🎯 Use this until Content Hub listing is live" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#2d7d32;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="690" width="820" height="160" as="geometry" />
        </mxCell>
        <mxCell id="path2" value="&lt;b&gt;② Content Hub (not yet, 🎯 strategic)&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="110" width="840" height="810" as="geometry" />
        </mxCell>
        <mxCell id="p2a" value="&lt;b&gt;Where customer finds it&lt;/b&gt;&#xa;Inside their Sentinel workspace → Content Hub → Browse&#xa;Search: &quot;SOCRadar&quot; or &quot;Entra ID&quot;&#xa;Filtered by: &quot;Publisher: SOCRadar&quot;, &quot;Type: Solution&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="160" width="800" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p2b" value="&lt;b&gt;What customer sees&lt;/b&gt;&#xa;• Logo, description, screenshots&#xa;• List of what's in the solution (playbooks, workbooks, analytics)&#xa;• Install button in Sentinel UI&#xa;• Version, author, support contact&#xa;• Microsoft-certified badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="280" width="800" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p2pros" value="&lt;b&gt;Pros&lt;/b&gt;&#xa;• Microsoft trust stamp&#xa;• Discoverable — customer searches, finds us&#xa;• BT güvenliği approves by default&#xa;• Update notifications in Sentinel UI&#xa;• Marketplace presence for sales&#xa;• Incidents/Feeds/TAXII already there — Entra ID missing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="460" width="400" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p2cons" value="&lt;b&gt;Cons&lt;/b&gt;&#xa;• One-time packaging work (2-3 sessions):&#xa;  V3 Solution tool, Data file, workbook refs,&#xa;  playbook ARMs, metadata JSON&#xa;• Microsoft Partner Center submission&#xa;• Review cycle (days to weeks)&#xa;• Must follow their branding/naming rules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1360" y="460" width="400" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p2status" value="&lt;b&gt;Current status — reality check&lt;/b&gt;&#xa;Nothing is LIVE on Sentinel Content Hub yet:&#xa;• Incidents: PR #13858 open in Azure/Azure-Sentinel, MS reviewer pending weeks/months&#xa;• Feeds: solution packaged locally, PR not opened yet&#xa;• TAXII: solution packaged locally, PR not opened yet&#xa;• Entra ID: ❌ not even packaged&#xa;&#xa;Decision needed for Entra ID: start packaging now, or wait for Incidents to clear first?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="690" width="800" height="220" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="8. Security Evolution" id="security">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="tsec" value="Security Evolution — Client Secret vs Federated Identity Credential" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tsecs" value="Today we store a password. Tomorrow we don't. Migration requires one-time customer coordination." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="cur" value="&lt;b&gt;CURRENT — Client Secret (password-based)&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="860" height="900" as="geometry" />
        </mxCell>
        <mxCell id="c1sec" value="&lt;b&gt;How it works&lt;/b&gt;&#xa;&#xa;1. Admin creates app registration → clicks &quot;New client secret&quot; → copies value&#xa;2. Secret is stored in Function App App Settings as ENTRA_CLIENT_SECRET (plaintext env var)&#xa;3. MSAL uses secret to acquire Graph token every ~60 minutes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="820" height="150" as="geometry" />
        </mxCell>
        <mxCell id="c2sec" value="&lt;b&gt;Risks&lt;/b&gt;&#xa;&#xa;• Secret in plaintext in App Settings — any portal user with Contributor role on the Function App can read it&#xa;• No KeyVault reference (not using @Microsoft.KeyVault(SecretUri=...) syntax)&#xa;• Secret expires after 2 years max — silent breakage when it does&#xa;• Rotation is manual: generate new → update setting → restart → verify → delete old&#xa;• If leaked, must revoke in app registration + rotate in all consumers&#xa;• Does NOT survive app registration deletion / migration easily" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="820" height="240" as="geometry" />
        </mxCell>
        <mxCell id="c3sec" value="&lt;b&gt;Code path&lt;/b&gt;&#xa;&#xa;# actions/entra_id.py:&#xa;app = ConfidentialClientApplication(&#xa;    client_id=client_id,&#xa;    client_credential=client_secret,   ← THE PASSWORD&#xa;    authority=f&quot;https://login.microsoftonline.com/{tenant_id}&quot;&#xa;)&#xa;result = app.acquire_token_for_client(scopes=[&quot;https://graph.microsoft.com/.default&quot;])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=14;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="590" width="820" height="220" as="geometry" />
        </mxCell>
        <mxCell id="c4sec" value="&lt;b&gt;Current required app settings&lt;/b&gt;&#xa;ENTRA_TENANT_ID · ENTRA_CLIENT_ID · &lt;b&gt;ENTRA_CLIENT_SECRET&lt;/b&gt; (plaintext)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="830" width="820" height="90" as="geometry" />
        </mxCell>
        <mxCell id="fut" value="&lt;b&gt;PROPOSED — Federated Identity Credential (passwordless)&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="110" width="840" height="900" as="geometry" />
        </mxCell>
        <mxCell id="f1sec" value="&lt;b&gt;How it works&lt;/b&gt;&#xa;&#xa;1. App registration adds a Federated Identity Credential (FIC) pointing to UAMI's issuer/subject&#xa;2. Function App's UAMI (already exists!) acquires its own Azure token&#xa;3. MSAL uses that token as client-assertion to get Graph token — no password&#xa;4. UAMI is managed by Azure, rotates automatically, can't leak" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="160" width="800" height="170" as="geometry" />
        </mxCell>
        <mxCell id="f2sec" value="&lt;b&gt;Benefits&lt;/b&gt;&#xa;&#xa;• No secret stored anywhere&#xa;• No rotation — UAMI auto-manages&#xa;• No expiration clock&#xa;• Can't be exfiltrated from App Settings (nothing to exfiltrate)&#xa;• Microsoft's recommended pattern for Azure-hosted daemons&#xa;• Unified with how we already auth to Storage + LAW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="350" width="800" height="210" as="geometry" />
        </mxCell>
        <mxCell id="f3sec" value="&lt;b&gt;Breaking change risk&lt;/b&gt;&#xa;&#xa;• Existing v1.0.0/v1.1.0 customers use client_secret&#xa;• Migration needs: (a) add FIC to app reg (one-time), (b) redeploy ARM&#xa;• Mitigation: keep both code paths for 2 versions → feature flag → sunset old" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="580" width="800" height="150" as="geometry" />
        </mxCell>
        <mxCell id="f4sec" value="&lt;b&gt;Decision gate&lt;/b&gt;&#xa;&#xa;Do we have production customers running?&#xa;&#xa;Yes → need phased migration plan, 2-week deprecation window&#xa;No → swap immediately, zero cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#2d7d32;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="750" width="800" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="9. Progress" id="progress">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="tp" value="Progress State — 2026-04-15" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tps" value="Four buckets: shipped → admin-blocked → your decision needed → strategic roadmap." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="c1p" value="✅ SHIPPED (on origin/master)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="440" height="1040" as="geometry" />
        </mxCell>
        <mxCell id="sh1" value="&lt;b&gt;33a4e7d&lt;/b&gt; Least-privilege refactor&#xa;• EnableUserLookup toggle&#xa;• 6 narrow Graph perms&#xa;• Sentinel labelType fix + severity&#xa;• Cross-RG workspaceResourceId fix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="400" height="130" as="geometry" />
        </mxCell>
        <mxCell id="sh2" value="&lt;b&gt;4dd0535&lt;/b&gt; v1.1.0 release + ARM URL fix&#xa;• FunctionApp.zip attached&#xa;• WEBSITE_RUN_FROM_PACKAGE updated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sh3" value="&lt;b&gt;ac1eb6a&lt;/b&gt; Force MFA Re-registration&#xa;• EnableForceMfaReregistration toggle&#xa;• 7 auth method types&#xa;• 401/403 graceful degrade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="430" width="400" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sh4" value="&lt;b&gt;cf83299&lt;/b&gt; Tests&#xa;• 7 mock unit tests (force MFA)&#xa;• test_actions test_13 (destructive)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="570" width="400" height="90" as="geometry" />
        </mxCell>
        <mxCell id="sh5" value="&lt;b&gt;e744a38 + 8f2b968&lt;/b&gt; CI + G2 throttling&#xa;• GitHub Actions CI&#xa;• _graph_request retry wrapper&#xa;• 8 new unit tests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="400" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sh6" value="&lt;b&gt;a0b5989&lt;/b&gt; G3 Consent revocation detection&#xa;• ConsentRevokedError classify AADSTS&#xa;• write_lifecycle_event&#xa;• 7 new unit tests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="810" width="400" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sh7" value="&lt;b&gt;3e95d30&lt;/b&gt; G7 auto-release workflow&#xa;on tag push → zip + release" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="940" width="400" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sh8" value="&lt;b&gt;4553e47&lt;/b&gt; G9 troubleshooting runbook&#xa;12 symptom/fix sections" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="1040" width="400" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c2p" value="⏸ ADMIN-BLOCKED" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="500" y="110" width="440" height="1040" as="geometry" />
        </mxCell>
        <mxCell id="b1p" value="&lt;b&gt;#7 Remove lingering broad grant&lt;/b&gt;&#xa;SP has User.ReadWrite.All still granted.&#xa;az rest DELETE call (in plan).&#xa;Needs Privileged Role Admin." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="160" width="400" height="140" as="geometry" />
        </mxCell>
        <mxCell id="b2p" value="&lt;b&gt;#5 Narrow-perm E2E tests&lt;/b&gt;&#xa;scripts/test_actions.py --skip-ropc&#xa;Only meaningful after #7 clears broad grant." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="320" width="400" height="120" as="geometry" />
        </mxCell>
        <mxCell id="b3p" value="&lt;b&gt;Force MFA live E2E test&lt;/b&gt;&#xa;Needs:&#xa;1. Grant UserAuthenticationMethod.ReadWrite.All&#xa;2. Assign Privileged Auth Admin role to SP&#xa;3. Disposable test user with MFA registered&#xa;4. test_actions.py --run-destructive&#xa;&#xa;Mock tests pass (7/7). Live test blocked." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="460" width="400" height="200" as="geometry" />
        </mxCell>
        <mxCell id="c3p" value="📋 NEEDS DECISION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="960" y="110" width="420" height="1040" as="geometry" />
        </mxCell>
        <mxCell id="d1p" value="&lt;b&gt;Q1: Content Hub for Entra ID&lt;/b&gt;&#xa;(Page 7 — Distribution)&#xa;&#xa;Publish this as Azure Marketplace solution?&#xa;Effort: 2-3 sessions + Partner Center review.&#xa;&#xa;• Yes → queue as Tier 3 roadmap&#xa;• Not yet → ARM button path stays" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="160" width="380" height="190" as="geometry" />
        </mxCell>
        <mxCell id="d2p" value="&lt;b&gt;Q2: Federated Identity migration&lt;/b&gt;&#xa;(Page 8 — Security Evolution)&#xa;&#xa;Kill ENTRA_CLIENT_SECRET?&#xa;&#xa;How many production customers running?&#xa;• 0 → swap immediately&#xa;• 1-5 → phased migration with feature flag&#xa;• many → 2-version deprecation window" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="370" width="380" height="200" as="geometry" />
        </mxCell>
        <mxCell id="d3p" value="&lt;b&gt;Q3: Option D — Programmatic CA&lt;/b&gt;&#xa;(Page 6 — Force MFA Options)&#xa;&#xa;Add Option D alongside existing A+C?&#xa;&#xa;• Yes → softer enforcement for P1/P2 customers&#xa;• No → Option A covers all cases (harder)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="590" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="d4p" value="&lt;b&gt;Q4: MSSP timing&lt;/b&gt;&#xa;(Pages 4 + 5 — MSSP Setup + Runtime)&#xa;&#xa;When does the first MSSP customer arrive?&#xa;&#xa;• This month → start Option 2 now&#xa;• Undefined → keep design, implement when demand lands" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="770" width="380" height="180" as="geometry" />
        </mxCell>
        <mxCell id="c4p" value="🎯 ROADMAP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="1400" y="110" width="360" height="1040" as="geometry" />
        </mxCell>
        <mxCell id="r1p" value="&lt;b&gt;Tier 2 (next batch)&lt;/b&gt;&#xa;&#xa;• G5 Integration test harness&#xa;  (mocked Graph)&#xa;• G10 Operational workbook tiles&#xa;  (error_rate, token_failures, 429s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1420" y="160" width="330" height="180" as="geometry" />
        </mxCell>
        <mxCell id="r2p" value="&lt;b&gt;Tier 3 (strategic)&lt;/b&gt;&#xa;&#xa;• G6 Content Hub solution package&#xa;  (if Q1 = yes)&#xa;• Option 2 MSSP multi-tenant&#xa;  (if Q4 = now)&#xa;• G1 Federated Identity Credential&#xa;  (if Q2 cleared)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1420" y="360" width="330" height="220" as="geometry" />
        </mxCell>
        <mxCell id="r3p" value="&lt;b&gt;Tier 4 (nice-to-have)&lt;/b&gt;&#xa;&#xa;• Option D programmatic CA&#xa;  (if Q3 = yes)&#xa;• Contract test against SOCRadar API&#xa;• Sentinel analytic rules for&#xa;  consent_revoked events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1420" y="600" width="330" height="200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
