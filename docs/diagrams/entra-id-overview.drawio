        </mxCell>
        <mxCell id="r16_4" value="If true, the plaintext leaked password is written to LAW. ⚠ Dangerous — only enable if security policy EXPLICITLY requires it." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="1005" width="640" height="50" as="geometry" />
