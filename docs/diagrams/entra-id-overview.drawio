        <mxCell id="n1" value="TIMER fires&#xa;(every 6 hours, run_on_startup=true)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="240" height="70" as="geometry" />
