        <mxCell id="r15_5" value="No extra perms (uses same SOCRadar API key as sources)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
