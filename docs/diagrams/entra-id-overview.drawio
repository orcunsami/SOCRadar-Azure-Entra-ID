<mxfile host="app.diagrams.net" modified="2026-04-15T17:25:00.000Z" agent="hand-crafted" version="24.0.0">
  <diagram name="0. Overview" id="toc">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="T0" value="SOCRadar Entra ID Integration — Complete Overview" style="text;strokeColor=none;fillColor=none;html=1;fontSize=28;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1520" height="50" as="geometry" />
        </mxCell>
        <mxCell id="T0s" value="Each tab in this file is a standalone page. Start with page 1 for architecture, then pick the topic you need." style="text;strokeColor=none;fillColor=none;html=1;fontSize=14;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="1520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="P1b" value="&lt;b&gt;1. Architecture&lt;/b&gt;&#xa;&#xa;Hangi bileşen neyle konuşuyor.&#xa;External servisler vs Azure kaynakları.&#xa;Endpoint URL'leri + auth yöntemi." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="P2b" value="&lt;b&gt;2. Runtime Flow&lt;/b&gt;&#xa;&#xa;Bir timer tick'inde ne oluyor.&#xa;SOCRadar fetch → user lookup → actions → LAW.&#xa;9 aksiyon seçeneği detaylı." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="450" y="160" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="P3b" value="&lt;b&gt;3. Feature Matrix&lt;/b&gt;&#xa;&#xa;Tüm ENABLE_* toggle'ları.&#xa;Her biri ne yapıyor, hangi permission gerektiriyor,&#xa;hangi lisansa bağlı." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="840" y="160" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="P4b" value="&lt;b&gt;4. MSSP: Setup Flow&lt;/b&gt;&#xa;&#xa;A firması X, Y'ye hizmet veriyor.&#xa;X ve Y admin'leri nasıl onay veriyor.&#xa;Tek deployment, 3 tenant." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1230" y="160" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="P5b" value="&lt;b&gt;5. MSSP: Runtime Flow&lt;/b&gt;&#xa;&#xa;Leak geldiğinde:&#xa;email domain → tenant lookup →&#xa;per-tenant token → per-tenant action." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="P6b" value="&lt;b&gt;6. Force MFA Options&lt;/b&gt;&#xa;&#xa;4 seçenek yan yana:&#xa;A=Delete methods · B=perUserMfaState&#xa;C=ConfirmRisky · D=Programmatic CA." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="450" y="360" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="P7b" value="&lt;b&gt;7. Distribution Paths&lt;/b&gt;&#xa;&#xa;Customer onboarding:&#xa;ARM button (var) vs Content Hub (yok).&#xa;Content Hub'a publish etmek ne kazandırır." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="840" y="360" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="P8b" value="&lt;b&gt;8. Security Evolution&lt;/b&gt;&#xa;&#xa;Şimdi: ENTRA_CLIENT_SECRET plaintext,&#xa;2 yıl TTL, elle rotation.&#xa;Hedef: Federated Identity Credential." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1230" y="360" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="P9b" value="&lt;b&gt;9. Progress State&lt;/b&gt;&#xa;&#xa;4 tier durum panosu:&#xa;✅ shipped · ⏸ admin-blocked&#xa;📋 pending decision · 🎯 roadmap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="lg" value="&lt;b&gt;Renk kodu:&lt;/b&gt;&#xa;🔵 Mavi = nasıl çalışıyor (architecture + runtime)&#xa;🟢 Yeşil = özellik envanteri + progress state&#xa;🟣 Mor = MSSP (multi-tenant konsept)&#xa;🟡 Sarı = feature karşılaştırma + distribution&#xa;🔴 Kırmızı = security / gelecekteki değişiklik" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="450" y="560" width="750" height="160" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="1. Architecture" id="arch">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t1" value="Architecture — Hub-and-Spoke" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t1s" value="Function App ortada. External servisler solda. Azure kaynakları sağda. Her ok bir HTTP çağrısı." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="ext" value="EXTERNAL SERVICES" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="440" height="900" as="geometry" />
        </mxCell>
        <mxCell id="socr" value="&lt;b&gt;SOCRadar Platform API&lt;/b&gt;&#xa;platform.socradar.com&#xa;&#xa;GET /botnet&#xa;GET /pii&#xa;GET /vip&#xa;POST /alarm/resolve&#xa;&#xa;Auth: X-Api-Key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="360" height="170" as="geometry" />
        </mxCell>
        <mxCell id="login" value="&lt;b&gt;login.microsoftonline.com&lt;/b&gt;&#xa;&#xa;POST /{tenant}/oauth2/v2.0/token&#xa;scope: graph.microsoft.com/.default&#xa;grant_type: client_credentials&#xa;&#xa;Returns: access_token (60m TTL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="graph" value="&lt;b&gt;Microsoft Graph v1.0&lt;/b&gt;&#xa;graph.microsoft.com&#xa;&#xa;GET /users/{email}&#xa;POST /users/{id}/revokeSignInSessions&#xa;POST /groups/{gid}/members/$ref&#xa;PATCH /users/{id}&#xa;POST /riskyUsers/confirmCompromised&#xa;GET /users/{id}/authentication/methods&#xa;DELETE /users/{id}/auth/.../{mid}&#xa;&#xa;Auth: Bearer token&#xa;Throttling: 429 Retry-After (retry wrapper)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="360" height="270" as="geometry" />
        </mxCell>
        <mxCell id="az" value="CUSTOMER AZURE SUBSCRIPTION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="640" y="110" width="1120" height="900" as="geometry" />
        </mxCell>
        <mxCell id="fa" value="&lt;b&gt;⚡ Azure Function App&lt;/b&gt;&#xa;&#xa;Python 3.11 / Consumption&#xa;Timer trigger (6h)&#xa;run_on_startup=true&#xa;&#xa;• function_app.py (entry)&#xa;• actions/* (Graph, Sentinel, LAW)&#xa;• sources/* (SOCRadar)&#xa;• utils/* (config, checkpoint)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=0;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="400" width="320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="uami" value="&lt;b&gt;🔑 User-Assigned MI&lt;/b&gt;&#xa;&#xa;DefaultAzureCredential&#xa;(AZURE_CLIENT_ID env)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="160" width="260" height="110" as="geometry" />
        </mxCell>
        <mxCell id="stor" value="&lt;b&gt;💾 Storage Account&lt;/b&gt;&#xa;&#xa;Table: EntraIDState&#xa;• PK=source&#xa;• RK=checkpoint&#xa;• last_start_date&#xa;• last_page" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=18;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=18;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="320" width="260" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ai" value="&lt;b&gt;📊 App Insights&lt;/b&gt;&#xa;&#xa;traces / requests /&#xa;exceptions / metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1440" y="160" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="law" value="&lt;b&gt;📋 Log Analytics Workspace&lt;/b&gt;&#xa;HTTP Data Collector API (HMAC)&#xa;&#xa;• SOCRadar_Botnet_CL&#xa;• SOCRadar_PII_CL&#xa;• SOCRadar_VIP_CL&#xa;• SOCRadar_Identity_CL&#xa;• SOCRadar_EntraID_Audit_CL" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=18;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=18;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="700" width="360" height="200" as="geometry" />
        </mxCell>
        <mxCell id="sent" value="&lt;b&gt;🚨 Microsoft Sentinel&lt;/b&gt;&#xa;(optional — ENABLE_CREATE_INCIDENT)&#xa;&#xa;PUT .../incidents/{guid}&#xa;Flows to SecurityIncident in LAW" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="700" width="400" height="150" as="geometry" />
