        <mxCell id="n2" value="config.load()&#xa;Read all ENABLE_* toggles + secrets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="180" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="_required_graph_permissions()&#xa;Log which permissions are needed based on config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="270" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="ENABLE_USER_LOOKUP?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="360" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n5a" value="FALSE branch:&#xa;Skip MSAL token&#xa;Skip all Entra actions&#xa;Only source fetch + LAW audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n5b" value="TRUE branch:&#xa;MSAL: POST /{tenant}/oauth2/v2.0/token&#xa;→ access_token (60-min TTL)&#xa;graph_headers = {Bearer ...}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="360" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n6" value="LOOP — for source in [botnet, pii, vip]" style="shape=process;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="480" width="360" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n7" value="Table Storage: GET checkpoint&#xa;(last_start_date, last_page)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n8" value="SOCRadar: GET /v2/.../search?...&#xa;Returns [{email, password, severity, ...}]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="560" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n9" value="Table Storage: PATCH new checkpoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="560" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n10" value="INNER LOOP — for emp in leaked_users" style="shape=process;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="660" width="360" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n11" value="Graph: GET /users/{email}&#xa;200 = found / 404 = not_found / 403 = perm denied" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="740" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n12" value="User found → Action chain (each opt-in)&#xa;&#xa;• enable_revoke_session → POST /revokeSignInSessions&#xa;• enable_add_to_group → POST /groups/{gid}/members/$ref&#xa;• enable_remove_from_group → DELETE members/{id}/$ref&#xa;• enable_disable_account → PATCH accountEnabled=false&#xa;• enable_enable_account → PATCH accountEnabled=true&#xa;• enable_password_change → PATCH passwordProfile&#xa;• enable_confirm_risky → POST /riskyUsers/confirmCompromised  [needs P1/P2]&#xa;• enable_force_mfa_reregistration ⭐ NEW → GET + DELETE auth methods&#xa;• enable_ropc → validate password via ROPC (if plaintext)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="830" width="720" height="200" as="geometry" />
        </mxCell>
        <mxCell id="n13" value="Log Analytics: POST SOCRadar_{source}_CL&#xa;(one record per employee with actions_taken[])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="1060" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n14" value="Sentinel (optional): PUT /incidents/{guid}&#xa;SOCRadar (optional): POST /alarms/{id}/resolve" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffffff;strokeColor=#666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="1150" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n15" value="END of tick&#xa;Write SOCRadar_EntraID_Audit_CL (3 rows)&#xa;Total: 1-32 seconds" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="1250" width="320" height="80" as="geometry" />
