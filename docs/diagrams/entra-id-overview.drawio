        <mxCell id="r15_4" value="After successful remediation, auto-resolve the originating SOCRadar alarm (closed loop for SOC)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
