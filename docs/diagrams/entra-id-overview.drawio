        <mxCell id="r15_2" value="RESOLVE_ALARM" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
