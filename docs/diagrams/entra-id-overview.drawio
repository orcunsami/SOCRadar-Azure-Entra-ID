        <mxCell id="new2" value="✅ YENİ YOL (v1.2.0+, şu an)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;verticalAlign=top;spacingTop=10;opacity=80;" vertex="1" parent="1"><mxGeometry x="920" y="80" width="840" height="780" as="geometry"/></mxCell>
        <mxCell id="n1" value="&lt;b&gt;1.&lt;/b&gt; ARM template UAMI oluşturur (otomatik, müşteri bir şey yapmaz)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="940" y="140" width="800" height="50" as="geometry"/></mxCell>
        <mxCell id="n2" value="&lt;b&gt;2.&lt;/b&gt; Admin assign_graph_roles.sh çalıştırır (bir kez)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="940" y="210" width="800" height="50" as="geometry"/></mxCell>
        <mxCell id="n3" value="&lt;b&gt;3.&lt;/b&gt; Kod: DefaultAzureCredential ile Graph token alır (UAMI otomatik)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="940" y="280" width="800" height="50" as="geometry"/></mxCell>
        <mxCell id="n4" value="&lt;b&gt;Kazanımlar:&lt;/b&gt;&#xa;✅ Secret YOK — saklayacak bir şey yok&#xa;✅ Expire YOK — zaman sınırı yok&#xa;✅ Rotation YOK — yönetecek bir şey yok&#xa;✅ Leak riski YOK — çalınacak bir şey yok&#xa;✅ App Registration GEREKMİYOR — bir adım daha az&#xa;✅ Aynı UAMI hem Storage hem Graph için (tek kimlik)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="940" y="360" width="800" height="260" as="geometry"/></mxCell>
        <mxCell id="ne1" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ne2" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ne3" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="migrate" value="→ Migration →" style="endArrow=classic;html=1;dashed=1;strokeColor=#666;strokeWidth=3;fontSize=14;fontStyle=1;" edge="1" parent="1" source="old" target="new2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rfnote" value="&lt;b&gt;Not:&lt;/b&gt; Recorded Future da Managed Identity kullanıyor. Bu endüstri standardı." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontStyle=2;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="40" y="870" width="1720" height="30" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="6. Standart" id="standard">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="Endüstri Standardı — Kim ne yapıyor, biz neredeyiz?" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1720" height="40" as="geometry"/></mxCell>
        <mxCell id="c1" value="✅ STANDART — Herkes yapıyor" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;opacity=80;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="420" height="360" as="geometry"/></mxCell>
        <mxCell id="s1" value="• Oturum iptal (session kill)&#xa;• Şifre değiştirmeye zorla&#xa;• Hesap devre dışı bırak&#xa;• LAW + Sentinel logging&#xa;• Secretless auth (MI)&#xa;&#xa;&lt;b&gt;Biz: ✅ hepsini yapıyoruz&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="130" width="380" height="280" as="geometry"/></mxCell>
        <mxCell id="c2" value="⭐ İLERİ — Biz + az sayıda rakip" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;opacity=80;" vertex="1" parent="1"><mxGeometry x="480" y="80" width="420" height="360" as="geometry"/></mxCell>
        <mxCell id="s2" value="• Confirm risky → CA trigger&#xa;• Checkpoint-based dedup&#xa;• Auto-resolve source alarm&#xa;&#xa;&lt;b&gt;Biz: ✅ hepsini yapıyoruz&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="500" y="130" width="380" height="280" as="geometry"/></mxCell>
        <mxCell id="c3" value="🏆 SADECE BİZ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;opacity=80;" vertex="1" parent="1"><mxGeometry x="920" y="80" width="420" height="360" as="geometry"/></mxCell>
        <mxCell id="s3" value="• Force MFA re-registration ⭐&#xa;• Quarantine group automation&#xa;• ROPC password validation&#xa;• Data-ingest-only mode&#xa;• 16 granular toggles&#xa;&#xa;&lt;b&gt;Rakipler bunları sunmuyor&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#9673a6;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="940" y="130" width="380" height="280" as="geometry"/></mxCell>
        <mxCell id="c4" value="❌ BİZDE EKSİK" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;opacity=80;" vertex="1" parent="1"><mxGeometry x="1360" y="80" width="400" height="360" as="geometry"/></mxCell>
        <mxCell id="s4" value="• Content Hub listing ❌&#xa;  (RF'de var, biz paketlemedik)&#xa;&#xa;• MSSP multi-tenant ❌&#xa;  (tasarım hazır, implement edilmedi)&#xa;&#xa;&lt;b&gt;Karar bekliyor — paketleme 2-3 gün&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1380" y="130" width="360" height="280" as="geometry"/></mxCell>
        <mxCell id="bottom" value="&lt;b&gt;Sonuç:&lt;/b&gt;  Ürün feature açısından endüstri standardının üstündeyiz. Eksik olan pazara giriş (Content Hub) ve kurumsal dağıtım (MSSP)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=14;align=center;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="1720" height="60" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="7. Senaryolar" id="scenarios">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="4 Müşteri Senaryosu — Leak geldiğinde her firma tipi için ne olur?" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1720" height="40" as="geometry"/></mxCell>
        <mxCell id="ts" value="Her sütun farklı bir firma tipi. Yeşil = açık olan toggle. Gri = kapalı. Kırmızı = kullanamaz (lisans yok)." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="40" y="62" width="1720" height="24" as="geometry"/></mxCell>
        <mxCell id="s1h" value="&lt;b&gt;SENARYO 1&lt;/b&gt;&#xa;🏠 Küçük firma (Free tier)&#xa;&#xa;&quot;Hızlı koruma istiyorum,&#xa;bütçem yok&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="110" width="420" height="1140" as="geometry"/></mxCell>
        <mxCell id="s1_src" value="&lt;b&gt;Kaynaklar&lt;/b&gt;&#xa;✅ Botnet (stealer log'ları)&#xa;✅ PII (breach dump'ları)&#xa;⬜ VIP (kapalı — unverified)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="230" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="s1_act" value="&lt;b&gt;Leak bulundu, user Entra'da eşleşti → ne olur:&lt;/b&gt;&#xa;&#xa;✅ Oturumları iptal et (hemen, otomatik)&#xa;✅ Karantina grubuna ekle&#xa;✅ Şifre değiştirmeye zorla&#xa;✅ Tüm MFA sil → yeniden register zorla ⭐&#xa;⬜ Hesap devre dışı bırak (çok sert, kapalı)&#xa;🔴 Confirm risky → KULLANAMAZ (P1/P2 yok)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="350" width="380" height="220" as="geometry"/></mxCell>
        <mxCell id="s1_out" value="&lt;b&gt;Çıktı:&lt;/b&gt;&#xa;✅ Log Analytics'e yaz (5 tablo)&#xa;⬜ Sentinel incident (kapalı — Sentinel yok)&#xa;⬜ SOCRadar alarm kapat (kapalı)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="590" width="380" height="110" as="geometry"/></mxCell>
        <mxCell id="s1_exp" value="&lt;b&gt;Kullanıcı ne yaşar:&lt;/b&gt;&#xa;&#xa;1. Tüm cihazlardan atılır (session kill)&#xa;2. Login'de &quot;MFA kayıt ol&quot; ekranı gelir&#xa;3. Sonra &quot;şifre değiştir&quot; ekranı gelir&#xa;4. Karantina grubundadır (IT fark eder)&#xa;&#xa;Saldırgan: eski şifre + eski MFA ise giremez." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="720" width="380" height="230" as="geometry"/></mxCell>
        <mxCell id="s1_cost" value="&lt;b&gt;Lisans maliyeti:&lt;/b&gt; $0 (Free tier yeterli)&#xa;&lt;b&gt;Kurulum:&lt;/b&gt; ARM deploy + admin script (30 sn)&#xa;&lt;b&gt;Bakım:&lt;/b&gt; Sıfır (secretless, rotation yok)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="970" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="s2h" value="&lt;b&gt;SENARYO 2&lt;/b&gt;&#xa;🏢 Enterprise (P1/P2 lisans)&#xa;&#xa;&quot;Tam koruma istiyorum,&#xa;Conditional Access var&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="480" y="110" width="420" height="1140" as="geometry"/></mxCell>
        <mxCell id="s2_src" value="&lt;b&gt;Kaynaklar&lt;/b&gt;&#xa;✅ Botnet&#xa;✅ PII&#xa;✅ VIP (exec'leri de izle)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="500" y="230" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="s2_act" value="&lt;b&gt;Leak bulundu, user Entra'da eşleşti → ne olur:&lt;/b&gt;&#xa;&#xa;✅ Oturumları iptal et&#xa;✅ Karantina grubuna ekle&#xa;✅ Şifre değiştirmeye zorla&#xa;✅ Confirm risky → CA policy MFA zorlar ⭐&#xa;⬜ Tüm MFA sil (kapalı — confirm risky yeterli)&#xa;⬜ Hesap devre dışı bırak (kapalı — çok sert)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="500" y="350" width="380" height="220" as="geometry"/></mxCell>
        <mxCell id="s2_out" value="&lt;b&gt;Çıktı:&lt;/b&gt;&#xa;✅ Log Analytics'e yaz (5 tablo)&#xa;✅ Sentinel incident aç (SOC takip eder)&#xa;✅ SOCRadar alarm otomatik kapat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="500" y="590" width="380" height="110" as="geometry"/></mxCell>
        <mxCell id="s2_exp" value="&lt;b&gt;Kullanıcı ne yaşar:&lt;/b&gt;&#xa;&#xa;1. Tüm cihazlardan atılır (session kill)&#xa;2. Login'de CA policy devreye girer&#xa;   → &quot;MFA gerekli&quot; (normal Authenticator prompt)&#xa;3. &quot;Şifre değiştir&quot; ekranı&#xa;4. SOC ekibi Sentinel'de incident görür&#xa;&#xa;Saldırgan: MFA'yı geçemez + şifre değişmiş." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="500" y="720" width="380" height="230" as="geometry"/></mxCell>
        <mxCell id="s2_cost" value="&lt;b&gt;Lisans maliyeti:&lt;/b&gt; P1 ~$6/user/ay veya P2 ~$9/user/ay&#xa;&lt;b&gt;Kurulum:&lt;/b&gt; ARM deploy + admin script + CA policy&#xa;&lt;b&gt;Bakım:&lt;/b&gt; Sıfır" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="500" y="970" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="s3h" value="&lt;b&gt;SENARYO 3&lt;/b&gt;&#xa;📋 Compliance / Audit&#xa;&#xa;&quot;Aksiyon alma, sadece&#xa;veri topla ve raporla&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="920" y="110" width="420" height="1140" as="geometry"/></mxCell>
        <mxCell id="s3_src" value="&lt;b&gt;Kaynaklar&lt;/b&gt;&#xa;✅ Botnet&#xa;✅ PII&#xa;✅ VIP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="940" y="230" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="s3_act" value="&lt;b&gt;ENABLE_USER_LOOKUP = false&lt;/b&gt;&#xa;(master gate kapalı)&#xa;&#xa;⬜ TÜM Entra aksiyonları kapalı&#xa;⬜ Graph API'ye hiç dokunulmaz&#xa;⬜ Entra credential'larına bile gerek yok&#xa;&#xa;Sadece SOCRadar'dan leak verisini çekip&#xa;Log Analytics'e yazmak." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="940" y="350" width="380" height="220" as="geometry"/></mxCell>
        <mxCell id="s3_out" value="&lt;b&gt;Çıktı:&lt;/b&gt;&#xa;✅ Log Analytics'e yaz (leak arşivi)&#xa;✅ KQL ile raporlama / dashboard&#xa;⬜ Sentinel / alarm kapatma (kapalı)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="940" y="590" width="380" height="110" as="geometry"/></mxCell>
        <mxCell id="s3_exp" value="&lt;b&gt;Kullanıcı ne yaşar:&lt;/b&gt;&#xa;&#xa;Hiçbir şey. Kullanıcı hiçbir müdahale görmez.&#xa;&#xa;IT ekibi Log Analytics'te şunu görür:&#xa;• Hangi çalışanın şifresi sızmış&#xa;• Hangi kaynaktan (botnet/breach/VIP)&#xa;• Ne zaman&#xa;• Kaç kez&#xa;&#xa;Manuel aksiyon alır veya almaz — karar onların." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="940" y="720" width="380" height="230" as="geometry"/></mxCell>
        <mxCell id="s3_cost" value="&lt;b&gt;Lisans maliyeti:&lt;/b&gt; $0 (Free tier, Graph bile gerekmiyor)&#xa;&lt;b&gt;Kurulum:&lt;/b&gt; ARM deploy (graph rolü bile gerekmiyor)&#xa;&lt;b&gt;Bakım:&lt;/b&gt; Sıfır" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="940" y="970" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="s4h" value="&lt;b&gt;SENARYO 4&lt;/b&gt;&#xa;🔒 VIP / Kritik Compromise&#xa;&#xa;&quot;CEO'nun şifresi sızdı,&#xa;EN SERT müdahale&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="1360" y="110" width="400" height="1140" as="geometry"/></mxCell>
        <mxCell id="s4_src" value="&lt;b&gt;Kaynaklar&lt;/b&gt;&#xa;✅ Botnet&#xa;✅ PII&#xa;✅ VIP (CEO/exec'ler için açık)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1380" y="230" width="360" height="100" as="geometry"/></mxCell>
        <mxCell id="s4_act" value="&lt;b&gt;HER ŞEY AÇIK — maksimum müdahale:&lt;/b&gt;&#xa;&#xa;✅ Oturumları iptal et&#xa;✅ Karantina grubuna ekle&#xa;✅ Şifre değiştirmeye zorla&#xa;✅ Tüm MFA sil → yeniden register&#xa;✅ HESABI DEVRE DIŞI BIRAK ⚠&#xa;✅ Confirm risky (P1/P2 varsa)&#xa;✅ ROPC ile şifre hâlâ geçerli mi kontrol" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1380" y="350" width="360" height="220" as="geometry"/></mxCell>
        <mxCell id="s4_out" value="&lt;b&gt;Çıktı:&lt;/b&gt;&#xa;✅ Log Analytics'e yaz&#xa;✅ Sentinel incident aç (ACİL severity)&#xa;✅ SOCRadar alarm otomatik kapat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1380" y="590" width="360" height="110" as="geometry"/></mxCell>
        <mxCell id="s4_exp" value="&lt;b&gt;Kullanıcı ne yaşar:&lt;/b&gt;&#xa;&#xa;1. Tüm cihazlardan atılır&#xa;2. HESAP KİTLENİR — login bile yapamaz&#xa;3. IT manuel olarak hesabı geri açar&#xa;4. Açıldığında: yeni şifre + yeni MFA kayıt&#xa;5. ROPC sonucu: eski şifre geçerli miydi&#xa;   raporda görülür (soruşturma kanıtı)&#xa;&#xa;Saldırgan: hiçbir yoldan giremez.&#xa;Kullanıcı: IT gelene kadar erişim yok." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1380" y="720" width="360" height="230" as="geometry"/></mxCell>
        <mxCell id="s4_cost" value="&lt;b&gt;Lisans:&lt;/b&gt; P1/P2 önerilir ama zorunlu değil&#xa;&lt;b&gt;Risk:&lt;/b&gt; Yanlış pozitif → CEO kilitlenir&#xa;&lt;b&gt;Öneri:&lt;/b&gt; Sadece VIP source'a özel kullanılmalı" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1380" y="970" width="360" height="100" as="geometry"/></mxCell>
        <mxCell id="bottom" value="&lt;b&gt;Senaryo seçimi müşteriye bırakılır&lt;/b&gt; — her toggle ARM deploy sırasında veya sonra Function App config'inden açılıp kapatılabilir. Yanlış seçim yapılırsa risk: false positive'de kullanıcı kitlenir (Senaryo 4) veya yetersiz müdahale (Senaryo 3). Önerilen başlangıç: Senaryo 1 (Free) veya Senaryo 2 (P1/P2)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="1260" width="1720" height="50" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="8. Aksiyon Akışı" id="actionflow">
    <mxGraphModel dx="1400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="Leak Geldiğinde Adım Adım Ne Olur?" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1120" height="40" as="geometry"/></mxCell>
        <mxCell id="ts" value="SOCRadar'dan bir leak geldiğinde, her adımda ne olduğunu gösterir. Yeşil kutular otomatik çalışır." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="40" y="60" width="1120" height="24" as="geometry"/></mxCell>
        <mxCell id="n1" value="&lt;b&gt;SOCRadar'dan leak geldi&lt;/b&gt;&#xa;email: ali@firma.com&#xa;password: *** (sanitize edilecek)&#xa;source: botnet / pii / vip&#xa;severity: CRITICAL / HIGH / MEDIUM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="340" y="100" width="520" height="130" as="geometry"/></mxCell>
        <mxCell id="n2" value="&lt;b&gt;ENABLE_USER_LOOKUP açık mı?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="420" y="270" width="360" height="80" as="geometry"/></mxCell>
        <mxCell id="n2no" value="&lt;b&gt;HAYIR → Sadece kayıt&lt;/b&gt;&#xa;&#xa;Leak verisi Log Analytics'e yazılır.&#xa;Entra'ya dokunulmaz.&#xa;Kullanıcıya müdahale yok.&#xa;(Senaryo 3 — compliance)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="40" y="280" width="320" height="160" as="geometry"/></mxCell>
        <mxCell id="n3" value="&lt;b&gt;Graph: ali@firma.com'u Entra'da ara&lt;/b&gt;&#xa;GET /users/ali@firma.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="400" y="400" width="400" height="60" as="geometry"/></mxCell>
        <mxCell id="n4" value="&lt;b&gt;Kullanıcı bulundu mu?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="420" y="500" width="360" height="80" as="geometry"/></mxCell>
        <mxCell id="n4no" value="&lt;b&gt;BULUNAMADI (404)&lt;/b&gt;&#xa;&#xa;Email bu tenant'ta yok.&#xa;entra_status = not_found&#xa;Log'a yazılır, aksiyon alınmaz." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="40" y="500" width="320" height="130" as="geometry"/></mxCell>
        <mxCell id="n5" value="&lt;b&gt;BULUNDU ✅ → Aksiyon zinciri başlar&lt;/b&gt;&#xa;Her toggle açıksa sırayla çalışır:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="300" y="620" width="600" height="50" as="geometry"/></mxCell>
        <mxCell id="a1" value="&lt;b&gt;1.&lt;/b&gt; Oturumları iptal et (revokeSignInSessions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="300" y="690" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="a2" value="&lt;b&gt;2.&lt;/b&gt; Karantina grubuna ekle (groups/members/$ref)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="300" y="740" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="a3" value="&lt;b&gt;3.&lt;/b&gt; Şifre değiştirmeye zorla (passwordProfile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="300" y="790" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="a4" value="&lt;b&gt;4.&lt;/b&gt; Hesabı devre dışı bırak (accountEnabled=false)  ⚠ SERT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="300" y="840" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="a5" value="&lt;b&gt;5.&lt;/b&gt; Confirm risky → CA policy devreye girer (P1/P2 gerekli)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="300" y="890" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="a6" value="&lt;b&gt;6.&lt;/b&gt; Tüm MFA sil → yeniden register zorla ⭐ YENİ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="300" y="940" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="a7" value="&lt;b&gt;7.&lt;/b&gt; ROPC: sızdırılan şifre hâlâ geçerli mi? (opsiyonel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="300" y="990" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="n6" value="&lt;b&gt;Log Analytics'e yaz&lt;/b&gt;&#xa;SOCRadar_{source}_CL tablosuna per-employee kayıt:&#xa;email, actions_taken, entra_status, mfa_methods_deleted, severity, timestamp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="300" y="1060" width="600" height="90" as="geometry"/></mxCell>
        <mxCell id="n7" value="&lt;b&gt;Opsiyonel çıktılar:&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#999;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="300" y="1180" width="600" height="35" as="geometry"/></mxCell>
        <mxCell id="n7a" value="Sentinel incident aç&#xa;(ENABLE_CREATE_INCIDENT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#999;fontSize=12;align=center;dashed=1;" vertex="1" parent="1"><mxGeometry x="300" y="1225" width="290" height="60" as="geometry"/></mxCell>
        <mxCell id="n7b" value="SOCRadar alarm kapat&#xa;(ENABLE_RESOLVE_ALARM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#999;fontSize=12;align=center;dashed=1;" vertex="1" parent="1"><mxGeometry x="610" y="1225" width="290" height="60" as="geometry"/></mxCell>
        <mxCell id="n8" value="&lt;b&gt;Sonraki leak'e geç — tüm source'lar bitene kadar&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="300" y="1320" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="n9" value="&lt;b&gt;Audit summary yaz → Bitti (1-32 saniye)&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="340" y="1400" width="520" height="60" as="geometry"/></mxCell>
        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;strokeWidth=2;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f2" value="hayır" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#999;strokeWidth=2;fontStyle=1;" edge="1" parent="1" source="n2" target="n2no"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f3" value="evet" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;strokeWidth=2;fontStyle=1;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;strokeWidth=2;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f5" value="hayır" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#999;strokeWidth=2;fontStyle=1;" edge="1" parent="1" source="n4" target="n4no"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f6" value="evet" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;strokeWidth=2;fontStyle=1;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="a7" target="n6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="n6" target="n7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="n7b" target="n8"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;" edge="1" parent="1" source="n8" target="n9"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="9. Yetenek Haritası" id="capabilities">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="Tam Yetenek Haritası — 24 özellik, 5 grup" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1720" height="40" as="geometry"/></mxCell>
        <mxCell id="terms" value="&lt;b&gt;Terimler:&lt;/b&gt;  Free tier = bedava Entra ID planı  ·  P1/P2 = ücretli Entra planı (Conditional Access içerir)  ·  CA = Conditional Access ('şu koşulda MFA zorla' kuralları)  ·  ROPC = şifre doğrulama denemesi  ·  MFA method = Authenticator/telefon/FIDO2 gibi 2FA kayıtları  ·  LAW = Log Analytics Workspace (log deposu)  ·  UAMI = Managed Identity (secretless kimlik)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="1720" height="60" as="geometry"/></mxCell>
        <mxCell id="g1h" value="① TEMEL — müdürün istediği 5 özellik (Free dahil hepsi)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="40" y="150" width="1720" height="35" as="geometry"/></mxCell>
        <mxCell id="g1" value="&lt;b&gt;1.&lt;/b&gt; Oturum iptal — tüm cihazlardan at, yeniden login zorla&#xa;&lt;b&gt;2.&lt;/b&gt; Şifre sıfırlama — sonraki login'de şifre değiştirmeye zorla&#xa;&lt;b&gt;3.&lt;/b&gt; Grup yönetimi — compromised user'ı karantina grubuna ekle/çıkar&#xa;&lt;b&gt;4.&lt;/b&gt; Hesap açma/kapama — hesabı tamamen kilitle veya geri aç&#xa;&lt;b&gt;5.&lt;/b&gt; Kullanıcı arama — leak'teki email'i Entra'da ara" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=14;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="185" width="1300" height="150" as="geometry"/></mxCell>
        <mxCell id="g1s" value="✅ 5/5 hazır&#xa;&#xa;Free tier dahil&#xa;herkes kullanabilir.&#xa;&#xa;Admin rol ataması&#xa;sonrası aktif." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="1360" y="185" width="400" height="150" as="geometry"/></mxCell>
        <mxCell id="g2h" value="② 2FA / MFA ZORLAMASI" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="40" y="355" width="1720" height="35" as="geometry"/></mxCell>
        <mxCell id="g2" value="&lt;b&gt;6.&lt;/b&gt; Force MFA re-registration — tüm MFA kayıtlarını sil, yeniden register zorla (Free dahil)&#xa;&lt;b&gt;7.&lt;/b&gt; Confirm compromised — 'ele geçirildi' işaretle, müşterinin CA kuralı MFA zorlar (P1/P2 gerekli)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=14;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="390" width="1300" height="80" as="geometry"/></mxCell>
        <mxCell id="g2s" value="✅ 2/2 hazır&#xa;#6 Free · #7 P1/P2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="1360" y="390" width="400" height="80" as="geometry"/></mxCell>
        <mxCell id="g3h" value="③ RAKIPLERDE OLMAYAN EKSTRALAR" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="40" y="490" width="1720" height="35" as="geometry"/></mxCell>
        <mxCell id="g3" value="&lt;b&gt;8.&lt;/b&gt; Şifre doğrulama (ROPC) — sızdırılan şifre hâlâ geçerli mi test et (RF'de yok)&#xa;&lt;b&gt;9.&lt;/b&gt; Alarm otomatik kapatma — aksiyon başarılıysa SOCRadar alarmını kapat (RF'de yok)&#xa;&lt;b&gt;10.&lt;/b&gt; Sentinel incident — her compromised user için Sentinel'de olay kaydı aç&#xa;&lt;b&gt;11.&lt;/b&gt; Sadece veri toplama modu — aksiyon almadan leak verisi topla / compliance (RF'de yok)&#xa;&lt;b&gt;12.&lt;/b&gt; Karantina grubu — user'ı otomatik güvenlik grubuna at (RF'de yok)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#9673a6;fontSize=13;align=left;spacingLeft=14;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="525" width="1300" height="160" as="geometry"/></mxCell>
        <mxCell id="g3s" value="✅ 5/5 hazır&#xa;Hepsi Free.&#xa;RF'de 4 tanesi YOK." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="1360" y="525" width="400" height="160" as="geometry"/></mxCell>
        <mxCell id="g4h" value="④ ALTYAPI / GÜVENLİK (görünmez ama kritik)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="40" y="705" width="1720" height="35" as="geometry"/></mxCell>
        <mxCell id="g4" value="&lt;b&gt;13.&lt;/b&gt; Secretless auth — şifre/secret yok, Managed Identity, expire yok&#xa;&lt;b&gt;14.&lt;/b&gt; Throttle koruması — API 'çok hızlısın' derse otomatik bekle + tekrar dene&#xa;&lt;b&gt;15.&lt;/b&gt; İzin iptal tespiti — müşteri yetkiyi geri alırsa audit event yazılır&#xa;&lt;b&gt;16.&lt;/b&gt; Uzun metin kesme — 30KB üstü veri kesilir, log limiti aşılmaz&#xa;&lt;b&gt;17.&lt;/b&gt; Tekrar işleme koruması — aynı leak iki kez işlenmez (checkpoint)&#xa;&lt;b&gt;18.&lt;/b&gt; Şifre gizleme — sızdırılan şifreler default'ta log'a yazılmaz&#xa;&lt;b&gt;19.&lt;/b&gt; 23 otomatik test + CI — her push'ta testler çalışır&#xa;&lt;b&gt;20.&lt;/b&gt; Sorun giderme rehberi — müşteri 12 yaygın sorunu kendi teşhis eder" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=14;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="740" width="1300" height="240" as="geometry"/></mxCell>
        <mxCell id="g4s" value="✅ 8/8 çalışıyor&#xa;&#xa;Endüstri standardı&#xa;+ üstü." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="1360" y="740" width="400" height="240" as="geometry"/></mxCell>
        <mxCell id="g5h" value="⑤ HENÜZ YAPILMAMIŞ (karar / talep bekliyor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="40" y="1000" width="1720" height="35" as="geometry"/></mxCell>
        <mxCell id="g5" value="&lt;b&gt;A.&lt;/b&gt; Content Hub listing — Sentinel marketplace'de görünme (paketleme 2-3 gün)&#xa;&lt;b&gt;B.&lt;/b&gt; MSSP multi-tenant — tek kurulum, birden fazla müşteri tenant'ına erişim (tasarım hazır, 1-2 gün)&#xa;&lt;b&gt;C.&lt;/b&gt; Programmatic CA policy — MFA silmeden kullanıcıya özel CA kuralı yaz (P1/P2, 1 gün)&#xa;&lt;b&gt;D.&lt;/b&gt; Domain filtresi — belirli domain'leri atla (talep gelirse 2 saat)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=13;align=left;spacingLeft=14;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="1035" width="1300" height="130" as="geometry"/></mxCell>
        <mxCell id="g5s" value="📋 4 beklemede&#xa;&#xa;Karar veya talep&#xa;bekleniyor." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="1360" y="1035" width="400" height="130" as="geometry"/></mxCell>
        <mxCell id="total" value="&lt;b&gt;TOPLAM: 24 yetenek — 20 hazır + 4 beklemede  ·  Free tier: 19 kullanılabilir  ·  P1/P2: 20 kullanılabilir&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;align=center;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="1190" width="1720" height="50" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="10. Müdürden İstenenler" id="adminactions">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="Müdürden İstenen Aksiyonlar" style="text;strokeColor=none;fillColor=none;html=1;fontSize=26;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1720" height="50" as="geometry"/></mxCell>
        <mxCell id="ts" value="Kod hazır, deploy edildi, test yazıldı. Aşağıdaki 3 aksiyon admin yetkisi gerektiriyor — biz yapamıyoruz." style="text;strokeColor=none;fillColor=none;html=1;fontSize=14;align=center;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="40" y="72" width="1720" height="30" as="geometry"/></mxCell>
        <mxCell id="a1box" value="&lt;b&gt;AKSİYON 1 — KRİTİK (30 saniye)&lt;/b&gt;&#xa;&#xa;UAMI'ye Graph API rollerini ata&#xa;&#xa;Ne yapılacak: Tek script çalıştır&#xa;&#xa;bash scripts/assign_graph_roles.sh&#xa;&#xa;Ne olur: 7 Graph rolü UAMI'ye atanır →&#xa;Function App tüm Entra aksiyonlarını&#xa;çalıştırabilir hale gelir.&#xa;&#xa;Şu an: UAMI token alabiliyor ama yetki yok → 403.&#xa;Bu yapıldıktan sonra: 403 → 200 olur.&#xa;&#xa;Neden admin lazım: Graph API rol ataması sadece&#xa;Privileged Role Admin / Global Admin yetkisiyle yapılabilir.&#xa;&#xa;Tek seferlik, bir daha dokunulmaz." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=20;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="560" height="450" as="geometry"/></mxCell>
        <mxCell id="a2box" value="&lt;b&gt;AKSİYON 2 — TEMİZLİK (10 saniye)&lt;/b&gt;&#xa;&#xa;Eski broad grant'ı kaldır&#xa;&#xa;Ne yapılacak:&#xa;Portal → App registrations →&#xa;SOCRadar-EntraID-Integration-Test →&#xa;API permissions → aşağı kaydır →&#xa;'Other permissions granted' bölümü →&#xa;User.ReadWrite.All satırında ... tıkla →&#xa;'Revoke admin consent' tıkla&#xa;&#xa;Ne olur: Eski geniş yetki kalkar.&#xa;App sadece 7 dar yetkiyle çalışır →&#xa;least-privilege kanıtlanır.&#xa;&#xa;Neden admin lazım: Consent revoke sadece&#xa;admin yetkisiyle yapılabilir." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=20;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="620" y="120" width="560" height="450" as="geometry"/></mxCell>
        <mxCell id="a3box" value="&lt;b&gt;AKSİYON 3 — OPSİYONEL (Force MFA testi için)&lt;/b&gt;&#xa;&#xa;Test kullanıcıya MFA register et&#xa;&#xa;Ne yapılacak:&#xa;testradar1@SOCRadarCyber... hesabına&#xa;Microsoft Authenticator veya telefon&#xa;numarası ile MFA kaydı yap.&#xa;&#xa;Ne olur: Force MFA Re-registration&#xa;özelliği canlı test edilebilir (MFA silme →&#xa;kullanıcı yeniden kayıt).&#xa;&#xa;Şu an: Test user'da 0 MFA method kayıtlı →&#xa;silinecek bir şey yok → test anlamsız.&#xa;&#xa;Bu yapılmazsa: Unit testler zaten geçiyor (7/7).&#xa;Canlı test sadece ekstra doğrulama." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=13;align=left;spacingLeft=20;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="1200" y="120" width="560" height="450" as="geometry"/></mxCell>
        <mxCell id="timeline" value="&lt;b&gt;Beklenen zaman çizelgesi:&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="600" width="1720" height="280" as="geometry"/></mxCell>
        <mxCell id="tl1" value="&lt;b&gt;Müdür aksiyonları yapar&lt;/b&gt;&#xa;(toplamda ~2 dakika)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="60" y="660" width="300" height="70" as="geometry"/></mxCell>
        <mxCell id="tl2" value="&lt;b&gt;Ben test çalıştırırım&lt;/b&gt;&#xa;test_actions.py + canlı function trigger&#xa;(~10 dakika)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="400" y="660" width="340" height="70" as="geometry"/></mxCell>
        <mxCell id="tl3" value="&lt;b&gt;Sonuçları raporlarım&lt;/b&gt;&#xa;Her action 200/204 → ✅&#xa;403 → ❌ (eksik yetki)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="780" y="660" width="340" height="70" as="geometry"/></mxCell>
        <mxCell id="tl4" value="&lt;b&gt;PRODUCTION READY&lt;/b&gt;&#xa;v1.2.0 release kesilir&#xa;README güncellenir&#xa;Müşteriye verilebilir" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffed;strokeColor=#2d7d32;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="1160" y="660" width="300" height="70" as="geometry"/></mxCell>
        <mxCell id="tla" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;strokeWidth=2;" edge="1" parent="1" source="tl1" target="tl2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="tlb" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;strokeWidth=2;" edge="1" parent="1" source="tl2" target="tl3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="tlc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;strokeWidth=2;" edge="1" parent="1" source="tl3" target="tl4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="tltime" value="~2 dk                           ~10 dk                           ~5 dk                            ✅ BİTTİ" style="text;strokeColor=none;fillColor=none;html=1;fontSize=12;align=center;fontColor=#555;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="60" y="740" width="1400" height="30" as="geometry"/></mxCell>
        <mxCell id="note" value="&lt;b&gt;NOT:&lt;/b&gt; Aksiyon 1 ve 2 olmadan app çalışır ama tüm Graph aksiyonları 403 döner. Sadece SOCRadar veri çekme + LAW yazma çalışır (Senaryo 3 — compliance mode)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="800" width="1720" height="50" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
