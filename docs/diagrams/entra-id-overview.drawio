<mxfile host="app.diagrams.net" modified="2026-04-17T13:35:00.000Z" agent="hand-crafted" version="24.0.0">
  <diagram name="1. Kavramlar" id="concepts">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="Kavramlar — Ne Nedir?" style="text;strokeColor=none;fillColor=none;html=1;fontSize=26;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1720" height="50" as="geometry"/></mxCell>
        <mxCell id="cloud" value="☁️ MICROSOFT BULUT KİMLİK SİSTEMİ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1"><mxGeometry x="40" y="90" width="860" height="480" as="geometry"/></mxCell>
        <mxCell id="entra" value="&lt;b&gt;Entra ID&lt;/b&gt;&#xa;(eski adı: Azure Active Directory)&#xa;&#xa;Bulut kimlik yönetimi.&#xa;Kullanıcılar, gruplar, uygulamalar burada." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="140" width="380" height="140" as="geometry"/></mxCell>
        <mxCell id="tenant" value="&lt;b&gt;Tenant&lt;/b&gt;&#xa;&#xa;Bir şirketin Entra ID'deki 'evi'.&#xa;Her şirketin benzersiz bir GUID'i var.&#xa;Tüm user/group/app burada yaşar." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="310" width="380" height="140" as="geometry"/></mxCell>
        <mxCell id="graph" value="&lt;b&gt;Microsoft Graph API&lt;/b&gt;&#xa;graph.microsoft.com/v1.0&#xa;&#xa;User, group, mail, security verilerine&#xa;tek erişim noktası. Her şey buradan.&#xa;Biz bu API'yi çağırıyoruz." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="480" y="140" width="380" height="160" as="geometry"/></mxCell>
        <mxCell id="auth" value="🔑 KİMLİK DOĞRULAMA" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1"><mxGeometry x="940" y="90" width="820" height="480" as="geometry"/></mxCell>
        <mxCell id="old" value="&lt;b&gt;App Registration + Client Secret&lt;/b&gt;&#xa;❌ ESKİ YOL — biz kaldırdık&#xa;&#xa;• Uygulama için kayıt oluştur&#xa;• Secret (şifre) generate et&#xa;• Secret'ı App Settings'e koy (plaintext!)&#xa;• 2 yılda expire olur, elle rotation lazım&#xa;• Leak riski, rotation derdi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="960" y="140" width="380" height="200" as="geometry"/></mxCell>
        <mxCell id="new" value="&lt;b&gt;UAMI (Managed Identity)&lt;/b&gt;&#xa;✅ YENİ YOL — şu an kullanıyoruz&#xa;&#xa;• Azure otomatik oluşturuyor&#xa;• Secret YOK, expire YOK, rotation YOK&#xa;• DefaultAzureCredential ile token alır&#xa;• Hem Storage hem Graph aynı identity&#xa;• App Registration GEREKMİYOR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="960" y="370" width="380" height="200" as="geometry"/></mxCell>
        <mxCell id="perm" value="&lt;b&gt;Graph Roles (izinler)&lt;/b&gt;&#xa;&#xa;UAMI'nin service principal'ına atanır.&#xa;assign_graph_roles.sh ile bir kez çalıştırılır.&#xa;&#xa;Örnekler:&#xa;• User.Read.All&#xa;• User.RevokeSessions.All&#xa;• GroupMember.ReadWrite.All&#xa;• UserAuthenticationMethod.ReadWrite.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1380" y="140" width="360" height="250" as="geometry"/></mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;strokeWidth=2;" edge="1" parent="1" source="entra" target="tenant"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#000;strokeWidth=2;" edge="1" parent="1" source="tenant" target="graph"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="new" target="graph"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3l" value="token al → Graph çağır" style="edgeLabel;html=1;align=center;fontSize=11;fontStyle=1;labelBackgroundColor=#fff;" vertex="1" connectable="0" parent="e3"><mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;strokeWidth=1;dashed=1;" edge="1" parent="1" source="new" target="perm"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4l" value="izinler buraya atanır" style="edgeLabel;html=1;align=center;fontSize=10;fontStyle=2;labelBackgroundColor=#fff;" vertex="1" connectable="0" parent="e4"><mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>
        <mxCell id="e5" value="artık kullanılmıyor" style="endArrow=classic;html=1;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="old" target="graph"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="summary" value="&lt;b&gt;Özetle:&lt;/b&gt; Entra ID = şirketin kimlik evi. Graph API = o eve erişim kapısı. UAMI = anahtarımız (şifresiz). Graph Role = o anahtarla ne yapabileceğimiz." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=13;align=left;spacingLeft=14;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="40" y="600" width="1720" height="70" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
