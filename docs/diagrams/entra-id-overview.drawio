<mxfile host="app.diagrams.net" modified="2026-04-15T18:35:00.000Z" agent="hand-crafted" version="24.0.0">
  <diagram name="1. Summary" id="summary">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t1" value="SOCRadar Entra ID Integration — What &amp; Why" style="text;strokeColor=none;fillColor=none;html=1;fontSize=26;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1720" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t1s" value="Automated response to compromised credentials. Customer deploys once, it runs every 6 hours, pulls leaks from SOCRadar, acts on matched Entra ID users, logs everything to Sentinel." style="text;strokeColor=none;fillColor=none;html=1;fontSize=14;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="1720" height="30" as="geometry" />
        </mxCell>
        <mxCell id="colIN" value="① DATA IN&#xa;(SOCRadar Platform)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1;verticalAlign=top;spacingTop=10;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="540" height="560" as="geometry" />
        </mxCell>
        <mxCell id="inA" value="&lt;b&gt;Botnet leaks&lt;/b&gt; ✅ default ON&#xa;Stealer malware log captures&#xa;→ Writes SOCRadar_Botnet_CL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="500" height="90" as="geometry" />
        </mxCell>
        <mxCell id="inB" value="&lt;b&gt;PII exposure&lt;/b&gt; ✅ default ON&#xa;Breach/darkweb email+password dumps&#xa;→ Writes SOCRadar_PII_CL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="500" height="90" as="geometry" />
        </mxCell>
        <mxCell id="inC" value="&lt;b&gt;VIP protection&lt;/b&gt; ⚠ default OFF&#xa;Exec/VIP-targeted leaks (unverified endpoint)&#xa;→ Writes SOCRadar_VIP_CL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="500" height="90" as="geometry" />
        </mxCell>
        <mxCell id="inInfo" value="&lt;b&gt;Domain filtering&lt;/b&gt;&#xa;Done on SOCRadar side (customer selects monitored&#xa;domains in platform). App processes everything the&#xa;API returns for the configured company_id.&#xa;&#xa;&lt;b&gt;Schedule&lt;/b&gt;  Timer trigger every 6 hours&#xa;  + one immediate run on startup/deploy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="500" height="180" as="geometry" />
        </mxCell>
        <mxCell id="colFA" value="② PROCESSING&#xa;(Function App in customer Azure)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;verticalAlign=top;spacingTop=10;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="620" y="140" width="560" height="560" as="geometry" />
        </mxCell>
        <mxCell id="faBig" value="&lt;b&gt;⚡ Azure Function App&lt;/b&gt;&#xa;Python 3.11 · Consumption tier&#xa;Timer trigger every 6h&#xa;&#xa;&lt;b&gt;Per tick&lt;/b&gt;&#xa;1. Load config (16 toggles + secrets)&#xa;2. Acquire Graph token via MSAL (unless lookup disabled)&#xa;3. For each enabled source: read checkpoint, fetch leaks,&#xa;   write new checkpoint&#xa;4. For each leak email: look up user in Entra,&#xa;   apply enabled actions, write LAW record&#xa;5. Write per-source audit summary to LAW&#xa;6. Optional: create Sentinel incident, resolve SOCRadar alarm&#xa;&#xa;&lt;b&gt;Built-in resilience&lt;/b&gt;&#xa;• 429 Retry-After handling (up to 3 retries, 30s cap)&#xa;• Consent revocation detection + audit event&#xa;• Per-source exception isolation&#xa;• Checkpoint resumes if interrupted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=14;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="200" width="520" height="480" as="geometry" />
        </mxCell>
        <mxCell id="colOUT" value="③ DATA OUT&#xa;(Entra + Sentinel + SOCRadar)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;verticalAlign=top;spacingTop=10;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="1220" y="140" width="540" height="560" as="geometry" />
        </mxCell>
        <mxCell id="outA" value="&lt;b&gt;Entra ID actions (9 options, opt-in)&lt;/b&gt;&#xa;Revoke session · Add/Remove group · Password change&#xa;Disable/Enable account · Confirm risky (P1/P2)&#xa;Force MFA re-registration ⭐ · ROPC validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1240" y="200" width="500" height="120" as="geometry" />
        </mxCell>
        <mxCell id="outB" value="&lt;b&gt;Log Analytics Workspace (always on)&lt;/b&gt;&#xa;5 custom tables: Botnet_CL, PII_CL, VIP_CL,&#xa;Identity_CL, EntraID_Audit_CL&#xa;5 pre-built workbooks deployed with ARM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1240" y="330" width="500" height="110" as="geometry" />
        </mxCell>
        <mxCell id="outC" value="&lt;b&gt;Microsoft Sentinel (optional)&lt;/b&gt;&#xa;Creates incident per compromised user,&#xa;labels with SOCRadar + source + LeakedCredential" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1240" y="450" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="outD" value="&lt;b&gt;SOCRadar feedback loop (optional)&lt;/b&gt;&#xa;Auto-resolves the originating alarm after successful&#xa;remediation, closes the loop so SOC doesn't&#xa;manually triage auto-handled cases." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1240" y="560" width="500" height="120" as="geometry" />
        </mxCell>
        <mxCell id="arrowIN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#6c8ebf;strokeWidth=3;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="colIN" target="colFA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrowOUT" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82b366;strokeWidth=3;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="colFA" target="colOUT">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="install" value="&lt;b&gt;How customers install&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="730" width="1720" height="260" as="geometry" />
        </mxCell>
        <mxCell id="inst1" value="&lt;b&gt;TODAY ✅&lt;/b&gt;  Deploy-to-Azure button on GitHub&#xa;&#xa;Customer clicks the button in our README.md →&#xa;Azure portal opens ARM template → customer fills&#xa;parameters (SOCRadar key, Entra credentials, LAW name)&#xa;→ click Create → ~3 minutes, live.&#xa;&#xa;Function code pulled from: GitHub Releases v1.1.0 zip&#xa;(auto-built on tag push via GitHub Actions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="780" width="820" height="190" as="geometry" />
        </mxCell>
        <mxCell id="inst2" value="&lt;b&gt;FUTURE 🎯&lt;/b&gt;  Microsoft Sentinel Content Hub&#xa;&#xa;Customer browses Sentinel → Content Hub → searches &quot;SOCRadar&quot;&#xa;→ finds our Entra ID solution → one-click install.&#xa;&#xa;Status today (2026-04-15):&#xa;• Incidents PR #13628 open in Azure-Sentinel — reviewer pending&#xa;• Feeds + TAXII packaged locally — PR not opened yet&#xa;• Entra ID — NOT PACKAGED YET (decision pending)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="780" width="820" height="190" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="&lt;b&gt;MSSP multi-tenant support&lt;/b&gt;  Designed (consent-per-customer-tenant, domain→tenant routing) but not yet implemented. 1-2 sessions of work when demand lands." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontStyle=2;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="1020" width="1720" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="2. Endpoints" id="endpoints">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t2" value="Endpoints &amp; Parameters — Every HTTP Call the App Makes" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t2s" value="Three owners, one Function App. Every endpoint listed with its parameters, auth method, and which toggle fires it." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1720" height="24" as="geometry" />
        </mxCell>
        <mxCell id="hdrSOCR" value="&lt;b&gt;SOCRadar Platform API&lt;/b&gt;    Owner: SOCRadar · Auth: X-Api-Key header    Host: platform.socradar.com" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="se1" value="&lt;b&gt;GET&lt;/b&gt; /api/company/{company_id}/v2/threat-feed/search/botnet&lt;br&gt;Params: start_date, end_date, page, limit&#xa;Fires when: ENABLE_BOTNET_SOURCE=true&#xa;Returns: list of botnet-leaked credentials" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="155" width="570" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se2" value="&lt;b&gt;GET&lt;/b&gt; /api/company/{company_id}/v2/incident/pii&#xa;Params: start_date, page, limit&#xa;Fires when: ENABLE_PII_SOURCE=true&#xa;Returns: PII exposure incidents with employee creds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="625" y="155" width="570" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se3" value="&lt;b&gt;GET&lt;/b&gt; /api/company/{company_id}/v2/incident/vip-protection&#xa;Params: start_date, page, limit&#xa;Fires when: ENABLE_VIP_SOURCE=true&#xa;⚠ UNVERIFIED — not in official API docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1200" y="155" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se4" value="&lt;b&gt;POST&lt;/b&gt; /api/company/{company_id}/incident/alarms/{alarm_id}/resolve&#xa;Body: {&quot;comment&quot;: &quot;User {email} found in Entra ID — auto-resolved&quot;}&#xa;Fires when: ENABLE_RESOLVE_ALARM=true AND user was found + acted&#xa;Purpose: close the alarm on SOCRadar side so SOC doesn't re-triage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="265" width="1710" height="95" as="geometry" />
        </mxCell>
        <mxCell id="hdrMSIP" value="&lt;b&gt;Microsoft identity platform&lt;/b&gt;    Owner: Microsoft · Auth: client credentials    Host: login.microsoftonline.com" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="se5" value="&lt;b&gt;POST&lt;/b&gt; /{tenant_id}/oauth2/v2.0/token&#xa;Body: grant_type=client_credentials &amp; client_id={app_id} &amp; client_secret={secret} &amp; scope=https://graph.microsoft.com/.default&#xa;Fires when: ENABLE_USER_LOOKUP=true (once per tick, token cached for 60 min)&#xa;Returns: access_token (Bearer) · 401 on consent revoked (AADSTS700016/65001/etc) · 7000215 if secret expired" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="425" width="1710" height="110" as="geometry" />
        </mxCell>
        <mxCell id="se6" value="&lt;b&gt;POST&lt;/b&gt; /{tenant_id}/oauth2/v2.0/token    [ROPC flow, NOT through retry wrapper]&#xa;Body: grant_type=password &amp; username={email} &amp; password={leaked_pwd} &amp; client_id={app_id} &amp; scope=openid&#xa;Fires when: ENABLE_ROPC=true AND plaintext password present&#xa;Returns: valid / invalid / mfa_blocked — validates whether the leaked password still works" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="545" width="1710" height="110" as="geometry" />
        </mxCell>
        <mxCell id="hdrMSG" value="&lt;b&gt;Microsoft Graph v1.0&lt;/b&gt;    Owner: Microsoft · Auth: Bearer token (with 429 Retry-After wrapper, 3 retries, 30s cap)    Host: graph.microsoft.com" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="675" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="se7" value="&lt;b&gt;GET&lt;/b&gt; /users/{email}&#xa;Fires: ENABLE_USER_LOOKUP=true per leaked email&#xa;Perm: User.Read.All&#xa;Returns: user object / 404 / 403" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="720" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se8" value="&lt;b&gt;POST&lt;/b&gt; /users/{id}/revokeSignInSessions&#xa;Fires: ENABLE_REVOKE_SESSION=true&#xa;Perm: User.RevokeSessions.All&#xa;Body: none · 204 on success" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="485" y="720" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se9" value="&lt;b&gt;POST&lt;/b&gt; /groups/{sec_group_id}/members/$ref&#xa;Body: {&quot;@odata.id&quot;: &quot;.../directoryObjects/{user_id}&quot;}&#xa;Fires: ENABLE_ADD_TO_GROUP=true + SECURITY_GROUP_ID&#xa;Perm: GroupMember.ReadWrite.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="920" y="720" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se10" value="&lt;b&gt;DELETE&lt;/b&gt; /groups/{sec_group_id}/members/{user_id}/$ref&#xa;Fires: ENABLE_REMOVE_FROM_GROUP=true&#xa;Perm: GroupMember.ReadWrite.All&#xa;204 on success, 404 if not a member" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1355" y="720" width="405" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se11" value="&lt;b&gt;PATCH&lt;/b&gt; /users/{id}&#xa;Body: {&quot;accountEnabled&quot;: false}&#xa;Fires: ENABLE_DISABLE_ACCOUNT=true&#xa;Perm: User.EnableDisableAccount.All · HIGH IMPACT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="830" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se12" value="&lt;b&gt;PATCH&lt;/b&gt; /users/{id}&#xa;Body: {&quot;accountEnabled&quot;: true}&#xa;Fires: ENABLE_ENABLE_ACCOUNT=true&#xa;Perm: User.EnableDisableAccount.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="485" y="830" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se13" value="&lt;b&gt;PATCH&lt;/b&gt; /users/{id}&#xa;Body: {&quot;passwordProfile&quot;: {&quot;forceChangePasswordNextSignIn&quot;: true}}&#xa;Fires: ENABLE_PASSWORD_CHANGE=true&#xa;Perm: User-PasswordProfile.ReadWrite.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="920" y="830" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se14" value="&lt;b&gt;POST&lt;/b&gt; /identityProtection/riskyUsers/confirmCompromised&#xa;Body: {&quot;userIds&quot;: [user_id]}&#xa;Fires: ENABLE_CONFIRM_RISKY=true&#xa;Perm: IdentityRiskyUser.ReadWrite.All · needs Entra P1/P2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1355" y="830" width="405" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se15" value="&lt;b&gt;GET&lt;/b&gt; /users/{id}/authentication/methods&#xa;then for each non-password method:&#xa;&lt;b&gt;DELETE&lt;/b&gt; /users/{id}/authentication/{methodsType}/{mid}&#xa;Fires: ENABLE_FORCE_MFA_REREGISTRATION=true · ⭐ NEW&#xa;Perm: UserAuthenticationMethod.ReadWrite.All + Privileged Auth Administrator role&#xa;Supported method types: Authenticator, phone, FIDO2, softwareOATH, Windows Hello, email, TAP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="940" width="1710" height="140" as="geometry" />
        </mxCell>
        <mxCell id="hdrMGMT" value="&lt;b&gt;Azure Resource Manager / Sentinel + Storage/LAW&lt;/b&gt;    Owner: Microsoft · Auth: Managed Identity or management.azure.com token" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="1100" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="se16" value="&lt;b&gt;PUT&lt;/b&gt; https://management.azure.com/subscriptions/{sub}/resourceGroups/{rg}/providers/Microsoft.OperationalInsights/workspaces/{ws}/providers/Microsoft.SecurityInsights/incidents/{guid}?api-version=2024-03-01&#xa;Fires: ENABLE_CREATE_INCIDENT=true&#xa;Body: {title, description, severity, status, labels:[{labelName, labelType:User}]}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="1145" width="850" height="140" as="geometry" />
        </mxCell>
        <mxCell id="se17" value="&lt;b&gt;POST&lt;/b&gt; https://{ws_id}.ods.opinsights.azure.com/api/logs?api-version=2016-04-01&#xa;Auth: HMAC-signed (SharedKey)&#xa;Fires: always (every tick writes per-employee records + audit summary + lifecycle events)&#xa;Log-Type: SOCRadar_Botnet / SOCRadar_PII / SOCRadar_VIP / SOCRadar_Identity / SOCRadar_EntraID_Audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="905" y="1145" width="855" height="140" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="3. Features" id="features">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t3" value="Features &amp; Configuration — 16 Toggles" style="text;strokeColor=none;fillColor=none;html=1;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t3s" value="Each row = one ARM parameter + app setting + code branch. Customer flips these at deploy time or via Function App configuration." style="text;strokeColor=none;fillColor=none;html=1;fontSize=13;align=center;fontColor=#555;" vertex="1" parent="1">
